<UserControl x:Class="TM.Framework.Notifications.NotificationManagement.DoNotDisturb.DoNotDisturbView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:layout="clr-namespace:TM.Framework.Common.Controls.Layout">

    <UserControl.Resources>

        <DataTemplate x:Key="TimeSpanItemTemplate">
            <TextBlock Text="{Binding StringFormat={}{0:hh\\:mm}}"/>
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="5">

            <Border CornerRadius="8" Padding="20" Margin="0,0,0,20">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#9E9E9E"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter Property="Background" Value="#4CAF50"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel HorizontalAlignment="Center">
                    <Image Source="{DynamicResource Icon.Moon}" Width="48" Height="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusText}" FontSize="18" FontWeight="SemiBold"
                               Foreground="White" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    <Button Content="切换状态" Command="{Binding ToggleCommand}"
                            Background="White" Foreground="{DynamicResource TextPrimary}"
                            Height="36" Padding="20,0" Margin="0,15,0,0"/>
                </StackPanel>
            </Border>

            <layout:IconHeaderGroupBox Icon="{DynamicResource Icon.Lightning}" Title="快捷操作" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="快速启用免打扰" FontSize="12"
                               Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,10"/>
                    <WrapPanel>
                        <Button Content="1小时" Command="{Binding QuickEnableCommand}" CommandParameter="1小时"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Height="32" Padding="15,0" Margin="0,0,10,0"/>
                        <Button Content="直到明天8:00" Command="{Binding QuickEnableCommand}" CommandParameter="直到明天8:00"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Height="32" Padding="15,0" Margin="0,0,10,0"/>
                        <Button Content="直到关闭" Command="{Binding QuickEnableCommand}" CommandParameter="直到手动关闭"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Height="32" Padding="15,0"/>
                    </WrapPanel>
                </StackPanel>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Icon="{DynamicResource Icon.Alarm}" Title="定时免打扰" Margin="0,0,0,20">
                <StackPanel>
                    <CheckBox Content="启用定时免打扰"
                              IsChecked="{Binding IsScheduleEnabled, Mode=TwoWay}"
                              Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,15" IsEnabled="{Binding IsScheduleEnabled}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="开始时间" VerticalAlignment="Center" Width="80"/>
                        <ComboBox Grid.Column="1" Height="36" Margin="10,0,0,0"
                                  ItemsSource="{Binding TimeOptions}"
                                  SelectedItem="{Binding StartTime, Mode=TwoWay}"
                                  ItemTemplate="{StaticResource TimeSpanItemTemplate}"/>
                    </Grid>

                    <Grid IsEnabled="{Binding IsScheduleEnabled}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="结束时间" VerticalAlignment="Center" Width="80"/>
                        <ComboBox Grid.Column="1" Height="36" Margin="10,0,0,0"
                                  ItemsSource="{Binding TimeOptions}"
                                  SelectedItem="{Binding EndTime, Mode=TwoWay}"
                                  ItemTemplate="{StaticResource TimeSpanItemTemplate}"/>
                    </Grid>
                </StackPanel>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Icon="{DynamicResource Icon.Settings}" Title="高级选项" Margin="0,0,0,20">
                <StackPanel>
                    <CheckBox Content="允许紧急通知穿透"
                              IsChecked="{Binding AllowUrgentNotifications, Mode=TwoWay}"
                              Margin="0,0,0,12"/>
                    <CheckBox Content="全屏应用时自动启用"
                              IsChecked="{Binding AutoEnableInFullscreen, Mode=TwoWay}"/>
                </StackPanel>
            </layout:IconHeaderGroupBox>

        </StackPanel>
    </ScrollViewer>
</UserControl>
