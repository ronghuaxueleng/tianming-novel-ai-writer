<Window x:Class="TM.Framework.Common.Controls.Feedback.ToastNotification"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        UseLayoutRounding="True"
        xmlns:local="clr-namespace:TM.Framework.Common.Controls.Feedback"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        SizeToContent="Height"
        ResizeMode="NoResize">

    <ItemsControl x:Name="ToastList" ItemsSource="{Binding}">
        <ItemsControl.ItemContainerStyle>
            <Style TargetType="ContentPresenter">
                <Setter Property="Opacity" Value="0"/>
            </Style>
        </ItemsControl.ItemContainerStyle>
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <StackPanel Orientation="Vertical"/>
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type local:ToastItem}">
                <Border Background="{Binding Background}"
                        BorderBrush="{DynamicResource GlassBorderBrush}"
                        CornerRadius="{Binding CornerRadius}"
                        BorderThickness="{Binding BorderThick}"
                        Padding="0"
                        MinHeight="{Binding MinItemHeight}"
                        MaxHeight="{Binding MaxItemHeight}"
                        Margin="{Binding ItemMargin}">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="0" BlurRadius="{Binding ShadowBlur}" Color="Black" Opacity="0.3" RenderingBias="Performance"/>
                    </Border.Effect>
                    <Grid>
                        <Grid HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="16,12,40,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Image Grid.Column="0" Source="{Binding Icon}" Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left">
                                <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" TextAlignment="Left" TextWrapping="Wrap" Foreground="White"/>
                                <TextBlock Text="{Binding Message}" FontSize="12" TextAlignment="Left" TextWrapping="Wrap" Margin="0"
                                           Foreground="{Binding MessageForeground}"
                                           Visibility="{Binding MessageVisibility}"/>
                            </StackPanel>
                        </Grid>

                        <Button Width="24" Height="24" Margin="0,6,6,0"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                BorderThickness="0" Cursor="Hand"
                                Command="{Binding CloseCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="CloseBtnBorder" Background="#01000000" CornerRadius="12">
                                        <Image Source="{DynamicResource Icon.Forbidden}" Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="CloseBtnBorder" Property="Background" Value="#20000000"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</Window>

