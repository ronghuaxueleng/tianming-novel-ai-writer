<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:TM.Framework.Common.Controls">

    <Style TargetType="{x:Type controls:MultiSelectComboBox}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Padding" Value="12,8,12,8"/>
        <Setter Property="FontFamily" Value="{DynamicResource GlobalFontFamily}"/>
        <Setter Property="FontSize" Value="{DynamicResource FontSizeNormal}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="{DynamicResource ContentBackgroundGlass}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:MultiSelectComboBox}">
                    <Grid>
                        <Border x:Name="templateRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="32"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0"
                                  Margin="{TemplateBinding Padding}"
                                  IsHitTestVisible="False">
                                <TextBlock x:Name="DisplayTextBlock"
                                           Text="{Binding DisplayText, RelativeSource={RelativeSource TemplatedParent}}"
                                           Foreground="{TemplateBinding Foreground}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock x:Name="PlaceholderTextBlock"
                                           Text="{TemplateBinding Placeholder}"
                                           Foreground="{DynamicResource TextTertiary}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Visibility="Collapsed"/>
                            </Grid>

                            <ToggleButton x:Name="PART_ToggleButton"
                                          Grid.Column="0"
                                          Grid.ColumnSpan="2"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"
                                                BorderThickness="0"
                                                SnapsToDevicePixels="True">
                                            <ContentPresenter HorizontalAlignment="Right"
                                                              VerticalAlignment="Center"
                                                              Margin="0,0,12,0"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <Path x:Name="arrow"
                                      Data="M 0 0 L 4 4 L 8 0 Z"
                                      Fill="{DynamicResource TextSecondary}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </ToggleButton>
                        </Grid>

                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               Placement="Bottom"
                               PlacementTarget="{Binding ElementName=templateRoot}"
                               IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                               StaysOpen="False"
                               Focusable="False"
                               PopupAnimation="Slide">

                            <Border Background="Transparent"
                                    Margin="0"
                                    Width="{Binding ActualWidth, ElementName=templateRoot}"
                                    MinWidth="{Binding ActualWidth, ElementName=templateRoot}">

                                <Border x:Name="dropDownBorder"
                                        Background="{DynamicResource DialogGlass}"
                                        BorderBrush="{DynamicResource GlassBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        MaxHeight="320"
                                        Padding="6"
                                        SnapsToDevicePixels="True">
                                    <ScrollViewer Background="Transparent"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsControl x:Name="PART_ItemsHost">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border x:Name="itemBorder"
                                                            Background="Transparent"
                                                            CornerRadius="6"
                                                            Margin="2"
                                                            Padding="6,4">
                                                        <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                  VerticalAlignment="Center"
                                                                  VerticalContentAlignment="Center"
                                                                  Foreground="{DynamicResource TextPrimary}">
                                                            <ContentPresenter Content="{Binding Item}"
                                                                              ContentTemplate="{Binding ItemTemplate, RelativeSource={RelativeSource AncestorType={x:Type controls:MultiSelectComboBox}}}"
                                                                              VerticalAlignment="Center"
                                                                              Margin="6,0,0,0"/>
                                                        </CheckBox>
                                                    </Border>
                                                    <DataTemplate.Triggers>
                                                        <Trigger SourceName="itemBorder" Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="itemBorder" Property="Background" Value="{DynamicResource HoverBackground}"/>
                                                        </Trigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                            </Border>
                        </Popup>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="templateRoot" Property="BorderBrush" Value="{DynamicResource PrimaryHover}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="templateRoot" Property="BorderBrush" Value="{DynamicResource PrimaryColor}"/>
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="templateRoot" Property="BorderBrush" Value="{DynamicResource PrimaryColor}"/>
                            <Setter TargetName="arrow" Property="Data" Value="M 0 4 L 4 0 L 8 4 Z"/>
                        </Trigger>
                        <Trigger Property="HasSelection" Value="False">
                            <Setter TargetName="DisplayTextBlock" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="PlaceholderTextBlock" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
