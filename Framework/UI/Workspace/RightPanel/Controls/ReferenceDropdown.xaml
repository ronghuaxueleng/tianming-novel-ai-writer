<UserControl x:Class="TM.Framework.UI.Workspace.RightPanel.Controls.ReferenceDropdown"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Popup x:Name="DropdownPopup"
           PlacementTarget="{Binding PlacementTarget}"
           Placement="Top"
           StaysOpen="False"
           AllowsTransparency="True"
           IsOpen="{Binding IsOpen, Mode=TwoWay}">

        <Grid Margin="12">

            <Border MinWidth="240"
                    MaxWidth="320"
                    MaxHeight="160"
                    CornerRadius="12"
                    Background="{DynamicResource ContentBackgroundGlass}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="20" Opacity="0.25" Color="#000" RenderingBias="Performance"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource SurfaceGlass}"
                            CornerRadius="11,11,0,0"
                            BorderBrush="{DynamicResource GlassBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Height="28"
                            Padding="6,0">
                        <TextBox x:Name="SearchBox"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 FontSize="12"
                                 Foreground="{DynamicResource TextPrimary}">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Grid>
                                                    <TextBlock Text="搜索引用..."
                                                               Foreground="{DynamicResource TextTertiary}"
                                                               VerticalAlignment="Center"
                                                               Visibility="{Binding Text.Length, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource InverseCountToVisibilityConverter}}"/>
                                                    <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                                </Grid>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Border>

                    <Border Grid.Row="1" CornerRadius="0,0,11,11" Background="Transparent">
                        <Grid>

                                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="3,2"
                                              Visibility="{Binding ShowTypes, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ItemsControl ItemsSource="{Binding ReferenceTypes}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Command="{Binding DataContext.SelectTypeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        HorizontalContentAlignment="Stretch"
                                                        Cursor="Hand"
                                                        Margin="3,1"
                                                        Height="30">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bg" Background="Transparent"
                                                                    CornerRadius="4"
                                                                    Padding="6,0">
                                                                <ContentPresenter VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bg" Property="Background" Value="{DynamicResource HoverBackground}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Image Source="{Binding Icon}"
                                                                         Width="11" Height="11"
                                                                         VerticalAlignment="Center"/>
                                                        <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" FontSize="12">
                                                            <Run Text="{Binding Type}" FontWeight="Medium" Foreground="{DynamicResource TextPrimary}"/>
                                                            <Run Text="：" Foreground="{DynamicResource TextSecondary}"/>
                                                            <Run Text="{Binding Description}" Foreground="{DynamicResource TextSecondary}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <ListBox ItemsSource="{Binding FilteredItems}"
                                         Padding="3,2"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Focusable="False"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.CanContentScroll="True"
                                         VirtualizingStackPanel.IsVirtualizing="True"
                                         VirtualizingStackPanel.VirtualizationMode="Recycling"
                                         VirtualizingPanel.ScrollUnit="Pixel"
                                         Visibility="{Binding ShowItems, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VirtualizingStackPanel />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <ContentPresenter HorizontalAlignment="Stretch"/>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.SelectItemCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    HorizontalContentAlignment="Stretch"
                                                    Cursor="Hand"
                                                    Margin="3,1"
                                                    Height="30">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bg" Background="Transparent"
                                                                CornerRadius="4"
                                                                Padding="6,0">
                                                            <ContentPresenter VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource HoverBackground}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource TextPrimary}"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </Button>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <TextBlock Text="未找到匹配项"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextTertiary}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="0,20"
                                           Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Popup>
</UserControl>
