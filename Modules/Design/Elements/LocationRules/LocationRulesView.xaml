<UserControl
    x:Class="TM.Modules.Design.Elements.LocationRules.LocationRulesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dm="clr-namespace:TM.Framework.Common.Controls.DataManagement"
    xmlns:layout="clr-namespace:TM.Framework.Common.Controls.Layout">
<dm:TwoColumnEditorLayout
    LeftIcon="{DynamicResource Icon.MapPin}"
    LeftTitle="位置规则"
    RightIcon="{DynamicResource Icon.MapPin}"
    RightTitle="规则编辑"
    ItemsSource="{Binding TreeData}"
    ShowSearch="True"
    SearchKeyword="{Binding SearchKeyword, Mode=TwoWay}"
    NodeDoubleClickCommand="{Binding SelectNodeCommand}"
    AddCommand="{Binding AddCommand}"
    SaveCommand="{Binding SaveCommand}"
    DeleteCommand="{Binding DeleteCommand}"
    DeleteAllCommand="{Binding DeleteAllCommand}"
    TreeAfterActionCommand="{Binding TreeAfterActionCommand}"
    UseStandardScheme2Layout="True"
    Tab1Header="基本信息"
    Tab2Header="地理特征"
    Tab3Header="故事关联">

    <dm:TwoColumnEditorLayout.EditAdditionalContent>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <layout:IconHeaderGroupBox Grid.Row="0" Icon="{DynamicResource Icon.MapPin}" Title="基础信息" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="位置类型" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimary}"/>
                    <ComboBox ItemsSource="{Binding LocationTypeOptions}"
                              SelectedItem="{Binding FormLocationType, Mode=TwoWay}"
                              Style="{DynamicResource StandardComboBoxStyle}" Height="36"
                              IsEditable="True"
                              ToolTip="区域/大陆、城市/聚落、自然地貌、建筑/设施、地点/场所、特殊空间"/>
                </StackPanel>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="1" Icon="{DynamicResource Icon.Ruler}" Title="规模/范围" Margin="0,0,0,10">
                <TextBox Text="{Binding FormScale, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"
                         ToolTip="描述位置的大小、覆盖范围等"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="2" Icon="{DynamicResource Icon.Edit}" Title="位置描述" Margin="0">
                <TextBox Text="{Binding FormDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>
        </Grid>
    </dm:TwoColumnEditorLayout.EditAdditionalContent>

    <dm:TwoColumnEditorLayout.DetailsContent>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <layout:IconHeaderGroupBox Grid.Row="0" Icon="{DynamicResource Icon.Mountain}" Title="地形/环境" Margin="0,0,0,10">
                <TextBox Text="{Binding FormTerrain, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"
                         ToolTip="山脉、平原、森林、沙漠、海洋等"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="1" Icon="{DynamicResource Icon.Thermometer}" Title="气候特征" Margin="0,0,0,10">
                <TextBox Text="{Binding FormClimate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"
                         ToolTip="温度、降水、季节变化等"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="2" Icon="{DynamicResource Icon.Institution}" Title="标志性建筑/地标" Margin="0,0,0,10">
                <TextBox Text="{Binding FormLandmarks, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"
                         ToolTip="著名建筑、标志性景观等"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="3" Icon="{DynamicResource Icon.Diamond}" Title="特产/资源" Margin="0">
                <TextBox Text="{Binding FormResources, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"
                         ToolTip="矿产、药材、特殊物品等"/>
            </layout:IconHeaderGroupBox>
        </Grid>
    </dm:TwoColumnEditorLayout.DetailsContent>

    <dm:TwoColumnEditorLayout.Tab3Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <layout:IconHeaderGroupBox Grid.Row="0" Icon="{DynamicResource Icon.Scroll}" Title="历史意义" Margin="0,0,0,10">
                <TextBox Text="{Binding FormHistoricalSignificance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"
                         ToolTip="这个地方在历史上的重要事件、意义"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="1" Icon="{DynamicResource Icon.Warning}" Title="危险/禁忌" Margin="0,0,0,10">
                <TextBox Text="{Binding FormDangers, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"
                         ToolTip="危险区域、禁忌、需要注意的事项"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="2" Icon="{DynamicResource Icon.Institution}" Title="所属势力（关联势力规则）" Margin="0">
                <ComboBox ItemsSource="{Binding AvailableFactions}"
                          SelectedItem="{Binding FormFactionId, Mode=TwoWay}"
                          Style="{DynamicResource StandardComboBoxStyle}" Height="36"
                          IsEditable="True"
                          ToolTip="下拉选择或输入势力名称"/>
            </layout:IconHeaderGroupBox>
        </Grid>
    </dm:TwoColumnEditorLayout.Tab3Content>

</dm:TwoColumnEditorLayout>
</UserControl>
