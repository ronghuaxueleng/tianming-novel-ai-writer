<UserControl x:Class="TM.Framework.UI.Workspace.RightPanel.Controls.ThinkingPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:TM.Framework.Common.Controls"
             xmlns:md="clr-namespace:TM.Framework.Common.Controls.Markdown"
             x:Name="RootControl">

    <StackPanel>
        <controls:BreathingLight IsActive="{Binding IsProcessing, ElementName=RootControl}"
                                 MinOpacity="0.3" MaxOpacity="1.0"
                                 HorizontalAlignment="Left">
            <TextBlock Text="{Binding EffectiveSummary, ElementName=RootControl, TargetNullValue=Thinking...}"
                       FontSize="9"
                       Foreground="{DynamicResource TextTertiary}"
                       Cursor="Hand">
                <TextBlock.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding ToggleCommand, ElementName=RootControl}"/>
                </TextBlock.InputBindings>
            </TextBlock>
        </controls:BreathingLight>

        <Border Margin="0,2,0,0"
                Background="{DynamicResource ContentBackgroundGlass}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="6,4,6,4"
                MinHeight="26"
                Visibility="{Binding IsExpanded, ElementName=RootControl, Converter={StaticResource BoolToVisibilityConverter}}">

            <ScrollViewer x:Name="ThinkingScrollViewer"
                          MaxHeight="150"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <md:MarkdownStreamViewer Markdown="{Binding AnalysisRaw, ElementName=RootControl}"
                                         IsStreamMode="{Binding IsProcessing, ElementName=RootControl}"
                                         EnableMarkdown="False"
                                         DocumentFontSize="10"
                                         DocumentLineHeight="14"
                                         DocumentForeground="{DynamicResource TextSecondary}"/>
            </ScrollViewer>
        </Border>
    </StackPanel>
</UserControl>
