<UserControl
    x:Class="TM.Modules.Design.Elements.FactionRules.FactionRulesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dm="clr-namespace:TM.Framework.Common.Controls.DataManagement"
    xmlns:layout="clr-namespace:TM.Framework.Common.Controls.Layout">
<dm:TwoColumnEditorLayout
    LeftIcon="{DynamicResource Icon.Institution}"
    LeftTitle="势力规则"
    RightIcon="{DynamicResource Icon.Institution}"
    RightTitle="规则编辑"
    ItemsSource="{Binding TreeData}"
    ShowSearch="True"
    SearchKeyword="{Binding SearchKeyword, Mode=TwoWay}"
    NodeDoubleClickCommand="{Binding SelectNodeCommand}"
    AddCommand="{Binding AddCommand}"
    SaveCommand="{Binding SaveCommand}"
    DeleteCommand="{Binding DeleteCommand}"
    DeleteAllCommand="{Binding DeleteAllCommand}"
    TreeAfterActionCommand="{Binding TreeAfterActionCommand}"
    UseStandardScheme2Layout="True"
    Tab1Header="基本信息"
    Tab2Header="核心成员"
    Tab3Header="对外关系">

    <dm:TwoColumnEditorLayout.EditAdditionalContent>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <layout:IconHeaderGroupBox Grid.Row="0" Icon="{DynamicResource Icon.Institution}" Title="基础信息" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="势力类型" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimary}"/>
                    <ComboBox ItemsSource="{Binding FactionTypeOptions}"
                              SelectedItem="{Binding FormFactionType, Mode=OneWay}"
                              Style="{DynamicResource StandardComboBoxStyle}" Height="36"
                              IsEditable="True"
                              Text="{Binding FormFactionType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              ToolTip="宗门/教派、王国/帝国、家族/世家、商盟/行会、军事组织、秘密组织、部落/氏族"/>
                </StackPanel>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="1" Icon="{DynamicResource Icon.Target}" Title="理念/目标" Margin="0,0,0,10">
                <TextBox Text="{Binding FormGoal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="2" Icon="{DynamicResource Icon.Map}" Title="实力/地盘" Margin="0">
                <TextBox Text="{Binding FormStrengthTerritory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>
        </Grid>
    </dm:TwoColumnEditorLayout.EditAdditionalContent>

    <dm:TwoColumnEditorLayout.DetailsContent>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <layout:IconHeaderGroupBox Grid.Row="0" Icon="{DynamicResource Icon.Crown}" Title="领袖" Margin="0,0,0,10">
                <TextBox Text="{Binding FormLeader, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource StandardTextBoxStyle}" Height="36"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="1" Icon="{DynamicResource Icon.Users}" Title="核心成员" Margin="0,0,0,10">
                <TextBox Text="{Binding FormCoreMembers, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="2" Icon="{DynamicResource Icon.Sparkle}" Title="成员特征（共同特点、行事风格）" Margin="0">
                <TextBox Text="{Binding FormMemberTraits, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>
        </Grid>
    </dm:TwoColumnEditorLayout.DetailsContent>

    <dm:TwoColumnEditorLayout.Tab3Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"/>

            <layout:IconHeaderGroupBox Grid.Row="1" Icon="{DynamicResource Icon.Handshake}" Title="盟友势力" Margin="0,0,0,10">
                <TextBox Text="{Binding FormAllies, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"
                         ToolTip="输入势力名称，每行一个"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="2" Icon="{DynamicResource Icon.Swords}" Title="敌对势力" Margin="0,0,0,10">
                <TextBox Text="{Binding FormEnemies, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"
                         ToolTip="输入势力名称，每行一个"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="3" Icon="{DynamicResource Icon.Refresh}" Title="中立/竞争关系" Margin="0">
                <TextBox Text="{Binding FormNeutralCompetitors, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"
                         ToolTip="输入势力名称，每行一个"/>
            </layout:IconHeaderGroupBox>
        </Grid>
    </dm:TwoColumnEditorLayout.Tab3Content>

</dm:TwoColumnEditorLayout>
</UserControl>
