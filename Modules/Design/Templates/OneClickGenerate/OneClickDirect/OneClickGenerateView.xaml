<UserControl x:Class="TM.Modules.Design.Templates.OneClickGenerate.OneClickDirect.OneClickGenerateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:TM.Modules.Design.Templates.OneClickGenerate.OneClickDirect"
             xmlns:layout="clr-namespace:TM.Framework.Common.Controls.Layout"
             xmlns:feedback="clr-namespace:TM.Framework.Common.Controls.Feedback"
             xmlns:controls="clr-namespace:TM.Framework.Common.Controls"
             mc:Ignorable="d"
             Loaded="OnLoaded"
             d:DesignHeight="700" d:DesignWidth="1200">

    <UserControl.Resources>
        <local:ZeroToEmptyStringConverter x:Key="ZeroToEmptyStringConverter" />
        <Style x:Key="StepTitleTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding TitleColorGroup}" Value="Template">
                    <Setter Property="Foreground" Value="{DynamicResource WarningColor}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding TitleColorGroup}" Value="World">
                    <Setter Property="Foreground" Value="{DynamicResource InfoColor}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding TitleColorGroup}" Value="DesignElements">
                    <Setter Property="Foreground" Value="{DynamicResource SuccessColor}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding TitleColorGroup}" Value="Outline">
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryColor}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding TitleColorGroup}" Value="GenerateElements">
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryHover}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Margin="0,5,5,0"
            Background="{DynamicResource SurfaceGlass}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <layout:IconHeaderGroupBox Grid.Column="0" Icon="{DynamicResource Icon.Lightning}" Title="一键直出 参数配置" BorderThickness="0">

                <ListBox ItemsSource="{Binding PipelineSteps}"
                         IsEnabled="{Binding IsParameterEditable}"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         BorderThickness="0" Background="Transparent">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter HorizontalAlignment="Stretch"/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource SurfaceGlass}"
                                        BorderBrush="{DynamicResource GlassBorderBrush}"
                                        BorderThickness="1" CornerRadius="6"
                                        Padding="12,10" Margin="0,0,0,8">
                                    <StackPanel>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Image Source="{Binding Icon}" Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding DisplayName, Mode=OneWay}" Style="{StaticResource StepTitleTextStyle}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding StepIndex, StringFormat=#{0}}"
                                                       Foreground="{DynamicResource TextTertiary}"
                                                       FontSize="12" VerticalAlignment="Center" />
                                        </Grid>

                                        <Grid Margin="0,8,0,0"
                                              Visibility="{Binding ShowCategoryInput, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="70" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="分类" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextSecondary}" FontSize="12" />
                                            <ComboBox Grid.Column="1"
                                                      ItemsSource="{Binding AvailableCategories}"
                                                      SelectedItem="{Binding CategoryName, Mode=OneWay}"
                                                      IsEditable="True"
                                                      Text="{Binding CategoryName, UpdateSourceTrigger=PropertyChanged}"
                                                      Style="{DynamicResource StandardComboBoxStyle}"
                                                      Height="30" FontSize="12" />
                                        </Grid>

                                        <Border Margin="0,8,0,0" CornerRadius="4" Padding="8,5"
                                                Background="{DynamicResource ContentHighlight}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ShowCategoryInput}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding DynamicCategoryHint}" FontSize="12"
                                                       Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" />
                                        </Border>

                                        <Grid Margin="0,6,0,0"
                                              Visibility="{Binding ShowCountInput, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="70" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="数量" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextSecondary}" FontSize="12" />
                                            <TextBox Grid.Column="1" Text="{Binding Count, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource ZeroToEmptyStringConverter}}"
                                                     Style="{DynamicResource StandardTextBoxStyle}"
                                                     Height="30" FontSize="12" />
                                        </Grid>

                                        <ItemsControl ItemsSource="{Binding ExtraFields}" Margin="0,6,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="70" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock VerticalAlignment="Center" FontSize="12"
                                                                   Foreground="{DynamicResource TextSecondary}">
                                                            <Run Text="{Binding Label, Mode=OneWay}" />
                                                            <Run Text="{Binding RequiredMark, Mode=OneWay}" Foreground="Red" />
                                                        </TextBlock>

                                                        <ComboBox Grid.Column="1"
                                                                  ItemsSource="{Binding AvailableOptions}"
                                                                  SelectedItem="{Binding Value, Mode=OneWay}"
                                                                  IsEditable="True"
                                                                  Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                                  Style="{DynamicResource StandardComboBoxStyle}"
                                                                  Height="30" FontSize="12"
                                                                  Visibility="{Binding IsDropdown, Converter={StaticResource BoolToVisibilityConverter}}" />

                                                        <TextBox Grid.Column="1" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                                 Height="30" FontSize="12">
                                                            <TextBox.Style>
                                                                <Style TargetType="TextBox" BasedOn="{StaticResource StandardTextBoxStyle}">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsDropdown}" Value="True">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBox.Style>
                                                        </TextBox>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

        </layout:IconHeaderGroupBox>

        <layout:IconHeaderGroupBox Grid.Column="2" Icon="{DynamicResource Icon.Chart}" Title="执行进度" BorderThickness="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="{Binding OverallProgressText}"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="12" />
                    </Grid>

                    <Grid Height="20">

                        <Border CornerRadius="10" Background="{DynamicResource ContentHighlight}" />

                        <Border CornerRadius="10" Background="{DynamicResource PrimaryColor}" HorizontalAlignment="Left">
                            <Border.Width>
                                <MultiBinding>
                                    <MultiBinding.Converter>
                                        <local:PercentWidthConverter />
                                    </MultiBinding.Converter>
                                    <Binding Path="OverallProgressPercent" Mode="OneWay" />
                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}" />
                                </MultiBinding>
                            </Border.Width>
                        </Border>
                        <Border CornerRadius="10" BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1" />
                        <TextBlock Text="{Binding OverallProgressPercent, StringFormat={}{0}%}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimary}" FontSize="12" FontWeight="SemiBold" />
                    </Grid>
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="3*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="2*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6">
                        <Run Text="▸ 设计模块" />
                    </TextBlock>
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding DesignSteps}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                                <Setter Property="VerticalAlignment" Value="Stretch" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:BreathingLight IsActive="{Binding IsRunning}"
                                                         MinOpacity="0.55" MaxOpacity="1.0"
                                                         Duration="1.6">
                                <Border Padding="10,10" Margin="0,0,6,6" CornerRadius="8">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource SurfaceGlass}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}" />
                                            <Setter Property="BorderThickness" Value="1" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static local:StepStatus.Running}">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryColor}" />
                                                    <Setter Property="BorderThickness" Value="2" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static local:StepStatus.Completed}">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource SuccessColor}" />
                                                    <Setter Property="BorderThickness" Value="2" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static local:StepStatus.Failed}">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource DangerColor}" />
                                                    <Setter Property="BorderThickness" Value="2" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="16" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                                            <Image Source="{Binding StatusIcon, Mode=OneWay}" Width="13" Height="13" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold" Margin="6,0,0,0"
                                                       Style="{StaticResource StepTitleTextStyle}" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <TextBlock Grid.Row="2" Margin="0" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"
                                                   Text="{Binding ProgressText, Mode=OneWay}"
                                                   FontWeight="SemiBold" Foreground="{DynamicResource PrimaryColor}" />
                                        <Grid Grid.Row="4" Height="16" VerticalAlignment="Bottom">
                                            <Border CornerRadius="8" Background="{DynamicResource ContentHighlight}"
                                                    BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1" />
                                            <Border CornerRadius="8" Background="{DynamicResource PrimaryColor}" HorizontalAlignment="Left">
                                                <Border.Width>
                                                    <MultiBinding>
                                                        <MultiBinding.Converter>
                                                            <local:PercentWidthConverter />
                                                        </MultiBinding.Converter>
                                                        <Binding Path="ProgressPercent" Mode="OneWay" />
                                                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}" />
                                                    </MultiBinding>
                                                </Border.Width>
                                            </Border>
                                            <TextBlock Text="{Binding ProgressPercent, StringFormat={}{0}%}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextPrimary}" FontSize="10" FontWeight="SemiBold" />
                                        </Grid>
                                    </Grid>
                                </Border>
                                </controls:BreathingLight>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Grid.Row="2" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,6">
                        <Run Text="▸ 创作模块" />
                    </TextBlock>
                    <ItemsControl Grid.Row="3" ItemsSource="{Binding GenerateSteps}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                                <Setter Property="VerticalAlignment" Value="Stretch" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:BreathingLight IsActive="{Binding IsRunning}"
                                                         MinOpacity="0.55" MaxOpacity="1.0"
                                                         Duration="1.6">
                                <Border Padding="10,10" Margin="0,0,6,6" CornerRadius="8">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource SurfaceGlass}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}" />
                                            <Setter Property="BorderThickness" Value="1" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static local:StepStatus.Running}">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryColor}" />
                                                    <Setter Property="BorderThickness" Value="2" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static local:StepStatus.Completed}">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource SuccessColor}" />
                                                    <Setter Property="BorderThickness" Value="2" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static local:StepStatus.Failed}">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource DangerColor}" />
                                                    <Setter Property="BorderThickness" Value="2" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="16" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                                            <Image Source="{Binding StatusIcon, Mode=OneWay}" Width="13" Height="13" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold" Margin="6,0,0,0"
                                                       Style="{StaticResource StepTitleTextStyle}" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <TextBlock Grid.Row="2" Margin="0" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"
                                                   Text="{Binding ProgressText, Mode=OneWay}"
                                                   FontWeight="SemiBold" Foreground="{DynamicResource PrimaryColor}" />
                                        <Grid Grid.Row="4" Height="16" VerticalAlignment="Bottom">
                                            <Border CornerRadius="8" Background="{DynamicResource ContentHighlight}"
                                                    BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1" />
                                            <Border CornerRadius="8" Background="{DynamicResource PrimaryColor}" HorizontalAlignment="Left">
                                                <Border.Width>
                                                    <MultiBinding>
                                                        <MultiBinding.Converter>
                                                            <local:PercentWidthConverter />
                                                        </MultiBinding.Converter>
                                                        <Binding Path="ProgressPercent" Mode="OneWay" />
                                                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}" />
                                                    </MultiBinding>
                                                </Border.Width>
                                            </Border>
                                            <TextBlock Text="{Binding ProgressPercent, StringFormat={}{0}%}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextPrimary}" FontSize="10" FontWeight="SemiBold" />
                                        </Grid>
                                    </Grid>
                                </Border>
                                </controls:BreathingLight>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>

                <Grid Grid.Row="2" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="2,0,12,0">
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextTertiary}"
                                   Text="· 数量填 0 → 跳过 AI 生成，仍可读取已有数据（可与手动生成混用）" />
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextTertiary}" Margin="0,3,0,0"
                                   Text="· 已完成步骤续传时自动跳过，「刷新重置」后状态清零重新生成" />
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextTertiary}" Margin="0,3,0,0"
                                   Text="· 分卷 / 章节 / 蓝图 无需配置，依赖前序步骤数据自动展开" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content=" 刷新重置"
                                Command="{Binding ResetPipelineCommand}"
                                Style="{DynamicResource DangerButtonStyle}"
                                Padding="14,8" FontSize="13" Margin="0,0,8,0" />
                        <Button Content="{Binding StartButtonText}"
                                Command="{Binding StartPipelineCommand}"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Padding="20,8" FontSize="13" />
                    </StackPanel>
                </Grid>

            </Grid>
        </layout:IconHeaderGroupBox>

    </Grid>
    </Border>
</UserControl>
