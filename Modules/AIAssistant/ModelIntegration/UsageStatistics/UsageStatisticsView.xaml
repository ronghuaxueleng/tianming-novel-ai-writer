<UserControl x:Class="TM.Modules.AIAssistant.ModelIntegration.UsageStatistics.UsageStatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:layout="clr-namespace:TM.Framework.Common.Controls.Layout"
             xmlns:local="clr-namespace:TM.Modules.AIAssistant.ModelIntegration.UsageStatistics">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Image Source="{DynamicResource Icon.Chart}" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="API使用统计"
                             FontSize="20"
                             FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimary}"
                             VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Command="{Binding RefreshCommand}"
                            Width="80"
                            Height="32"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{DynamicResource Icon.Refresh}" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="刷新" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ClearCommand}"
                            Width="80"
                            Height="32">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{DynamicResource Icon.Trash}" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="清空" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <layout:IconHeaderGroupBox Icon="{DynamicResource Icon.Chart}" Title="总体统计" Margin="0,0,0,15">
                <StackPanel>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                            <TextBlock Text="总调用次数"
                                     FontSize="12"
                                     Foreground="{DynamicResource TextSecondary}"
                                     Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding Summary.TotalCalls}"
                                     FontSize="24"
                                     FontWeight="SemiBold"
                                     Foreground="{DynamicResource PrimaryColor}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,15,0">
                            <TextBlock Text="成功率"
                                     FontSize="12"
                                     Foreground="{DynamicResource TextSecondary}"
                                     Margin="0,0,0,5"/>
                            <TextBlock FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource SuccessColor}">
                                <Run Text="{Binding Summary.SuccessRate, Mode=OneWay, StringFormat='{}{0:F1}'}"/>
                                <Run Text="%" FontSize="16"/>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,15,0">
                            <TextBlock Text="平均响应时间"
                                     FontSize="12"
                                     Foreground="{DynamicResource TextSecondary}"
                                     Margin="0,0,0,5"/>
                            <TextBlock FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource InfoColor}">
                                <Run Text="{Binding Summary.AverageResponseTime, StringFormat='{}{0:F0}'}"/>
                                <Run Text="ms" FontSize="16"/>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Grid.Column="3">
                            <TextBlock Text="失败次数"
                                     FontSize="12"
                                     Foreground="{DynamicResource TextSecondary}"
                                     Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding Summary.FailedCalls}"
                                     FontSize="24"
                                     FontWeight="SemiBold"
                                     Foreground="{DynamicResource DangerColor}"/>
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                            <TextBlock Text="累计输入 Tokens"
                                     FontSize="12"
                                     Foreground="{DynamicResource TextSecondary}"
                                     Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding Summary.TotalInputTokens, StringFormat='{}{0:N0}'}"
                                     FontSize="20"
                                     FontWeight="SemiBold"
                                     Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,15,0">
                            <TextBlock Text="累计输出 Tokens"
                                     FontSize="12"
                                     Foreground="{DynamicResource TextSecondary}"
                                     Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding Summary.TotalOutputTokens, StringFormat='{}{0:N0}'}"
                                     FontSize="20"
                                     FontWeight="SemiBold"
                                     Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,15,0">
                            <TextBlock Text="平均首 Token 延迟 (TTFB)"
                                     FontSize="12"
                                     Foreground="{DynamicResource TextSecondary}"
                                     Margin="0,0,0,5"/>
                            <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}">
                                <Run Text="{Binding Summary.AverageFirstTokenMs, StringFormat='{}{0:F0}'}"/>
                                <Run Text="ms" FontSize="14"/>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Grid.Column="3">
                            <TextBlock Text="平均速度 (Tokens/秒)"
                                     FontSize="12"
                                     Foreground="{DynamicResource TextSecondary}"
                                     Margin="0,0,0,5"/>
                            <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}">
                                <Run Text="{Binding Summary.AverageTokensPerSecond, StringFormat='{}{0:F1}'}"/>
                                <Run Text="tok/s" FontSize="14"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Icon="{DynamicResource Icon.Calendar}" Title="最近7天统计" Margin="0,0,0,15">
                <DataGrid ItemsSource="{Binding DailyStats}"
                             AutoGenerateColumns="False"
                             CanUserAddRows="False"
                             CanUserDeleteRows="False"
                             IsReadOnly="True"
                             GridLinesVisibility="None"
                             Background="Transparent"
                             BorderThickness="0"
                             HeadersVisibility="Column"
                             RowHeight="36">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="日期" Binding="{Binding Date, Mode=OneWay, StringFormat='MM-dd'}" Width="80"/>
                        <DataGridTextColumn Header="调用次数" Binding="{Binding TotalCalls, Mode=OneWay}" Width="*"/>
                        <DataGridTextColumn Header="成功" Binding="{Binding SuccessCalls, Mode=OneWay}" Width="*"/>
                        <DataGridTextColumn Header="失败" Binding="{Binding FailedCalls, Mode=OneWay}" Width="*"/>
                        <DataGridTextColumn Header="平均响应时间(ms)" Binding="{Binding AverageResponseTime, Mode=OneWay, StringFormat='{}{0:F0}'}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Icon="{DynamicResource Icon.Robot}" Title="按模型统计" Margin="0,0,0,15">
                <DataGrid ItemsSource="{Binding ModelStats}"
                             AutoGenerateColumns="False"
                             CanUserAddRows="False"
                             CanUserDeleteRows="False"
                             IsReadOnly="True"
                             GridLinesVisibility="None"
                             Background="Transparent"
                             BorderThickness="0"
                             HeadersVisibility="Column"
                             RowHeight="36">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="模型" Binding="{Binding ModelName, Mode=OneWay}" Width="2*"/>
                        <DataGridTextColumn Header="调用次数" Binding="{Binding TotalCalls, Mode=OneWay}" Width="*"/>
                        <DataGridTextColumn Header="成功率(%)" Binding="{Binding SuccessRate, Mode=OneWay, StringFormat='{}{0:F1}'}" Width="*"/>
                        <DataGridTextColumn Header="平均响应时间(ms)" Binding="{Binding AverageResponseTime, Mode=OneWay, StringFormat='{}{0:F0}'}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Icon="{DynamicResource Icon.Edit}" Title="最近50次调用" Margin="0,0,0,0">
                <DataGrid ItemsSource="{Binding RecentCalls}"
                             AutoGenerateColumns="False"
                             CanUserAddRows="False"
                             CanUserDeleteRows="False"
                             IsReadOnly="True"
                             GridLinesVisibility="None"
                             Background="Transparent"
                             BorderThickness="0"
                             HeadersVisibility="Column"
                             RowHeight="36"
                             MaxHeight="400">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="时间" Binding="{Binding Timestamp, Mode=OneWay, StringFormat='MM-dd HH:mm:ss'}" Width="120"/>
                        <DataGridTextColumn Header="模型" Binding="{Binding ModelName, Mode=OneWay}" Width="1.5*"/>
                        <DataGridTextColumn Header="状态" Width="60">
                            <DataGridTextColumn.Binding>
                                <Binding Path="Success" Mode="OneWay">
                                    <Binding.Converter>
                                        <local:SuccessToTextConverter/>
                                    </Binding.Converter>
                                </Binding>
                            </DataGridTextColumn.Binding>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="响应(ms)" Binding="{Binding ResponseTimeMs, Mode=OneWay}" Width="80"/>
                        <DataGridTextColumn Header="首Token(ms)" Binding="{Binding FirstTokenMs, Mode=OneWay}" Width="90"/>
                        <DataGridTextColumn Header="TPS" Binding="{Binding TokensPerSecond, Mode=OneWay, StringFormat='{}{0:F1}'}" Width="70"/>
                        <DataGridTextColumn Header="输入Tokens" Binding="{Binding InputTokens, Mode=OneWay}" Width="90"/>
                        <DataGridTextColumn Header="输出Tokens" Binding="{Binding OutputTokens, Mode=OneWay}" Width="90"/>
                        <DataGridTextColumn Header="工具调用" Binding="{Binding ToolCallCount, Mode=OneWay}" Width="80"/>
                        <DataGridTextColumn Header="错误信息" Binding="{Binding ErrorMessage, Mode=OneWay}" Width="2*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </layout:IconHeaderGroupBox>

        </StackPanel>
    </ScrollViewer>

</UserControl>
