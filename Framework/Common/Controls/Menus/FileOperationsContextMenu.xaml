<ContextMenu x:Class="TM.Framework.Common.Controls.Menus.FileOperationsContextMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:TM.Framework.Common.Controls.Menus"
             xmlns:helpers="clr-namespace:TM.Framework.Common.Helpers.UI"
             helpers:RefreshEffectHelper.EnableRefreshEffect="True">

    <ContextMenu.Template>
        <ControlTemplate TargetType="ContextMenu">
            <Border CornerRadius="8"
                    Background="{DynamicResource DialogGlass}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1"
                    Padding="4"
                    SnapsToDevicePixels="True">
                <ScrollViewer CanContentScroll="True"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsPresenter/>
                </ScrollViewer>
            </Border>
        </ControlTemplate>
    </ContextMenu.Template>

    <MenuItem Header="刷新"
              Command="{Binding RefreshCommand, RelativeSource={RelativeSource AncestorType={x:Type local:FileOperationsContextMenu}}}"
          CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
              CommandParameter="{Binding DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
        <MenuItem.Icon>
            <Image Source="{DynamicResource Icon.Refresh}" Width="13" Height="13"/>
        </MenuItem.Icon>
    </MenuItem>

    <Separator/>

    <MenuItem Header="新建文件"
              Command="{Binding CreateFileCommand, RelativeSource={RelativeSource AncestorType={x:Type local:FileOperationsContextMenu}}}"
          CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
              CommandParameter="{Binding DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
        <MenuItem.Icon>
            <Image Source="{DynamicResource Icon.Document}" Width="13" Height="13"/>
        </MenuItem.Icon>
    </MenuItem>

    <MenuItem Header="新建文件夹"
              Command="{Binding CreateFolderCommand, RelativeSource={RelativeSource AncestorType={x:Type local:FileOperationsContextMenu}}}"
          CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
              CommandParameter="{Binding DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
        <MenuItem.Icon>
            <Image Source="{DynamicResource Icon.Folder}" Width="13" Height="13"/>
        </MenuItem.Icon>
    </MenuItem>

    <Separator/>

    <MenuItem Header="在资源管理器中打开"
              Command="{Binding RevealInExplorerCommand, RelativeSource={RelativeSource AncestorType={x:Type local:FileOperationsContextMenu}}}"
          CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
              CommandParameter="{Binding DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
        <MenuItem.Icon>
            <Image Source="{DynamicResource Icon.FolderOpen}" Width="13" Height="13"/>
        </MenuItem.Icon>
    </MenuItem>

    <MenuItem Header="复制"
              Command="{Binding CopyCommand, RelativeSource={RelativeSource AncestorType={x:Type local:FileOperationsContextMenu}}}"
          CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
              CommandParameter="{Binding DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
        <MenuItem.Icon>
            <Image Source="{DynamicResource Icon.Clipboard}" Width="13" Height="13"/>
        </MenuItem.Icon>
    </MenuItem>

    <MenuItem Header="粘贴"
              Command="{Binding PasteCommand, RelativeSource={RelativeSource AncestorType={x:Type local:FileOperationsContextMenu}}}"
          CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
              CommandParameter="{Binding DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
        <MenuItem.Icon>
            <Image Source="{DynamicResource Icon.Download}" Width="13" Height="13"/>
        </MenuItem.Icon>
    </MenuItem>

    <Separator/>

    <MenuItem Header="重命名"
              Command="{Binding RenameCommand, RelativeSource={RelativeSource AncestorType={x:Type local:FileOperationsContextMenu}}}"
          CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
              CommandParameter="{Binding DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
        <MenuItem.Icon>
            <Image Source="{DynamicResource Icon.Edit}" Width="13" Height="13"/>
        </MenuItem.Icon>
    </MenuItem>

    <MenuItem Header="删除"
              Command="{Binding DeleteCommand, RelativeSource={RelativeSource AncestorType={x:Type local:FileOperationsContextMenu}}}"
          CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
              CommandParameter="{Binding DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
        <MenuItem.Icon>
            <Image Source="{DynamicResource Icon.Trash}" Width="13" Height="13"/>
        </MenuItem.Icon>
    </MenuItem>

</ContextMenu>

