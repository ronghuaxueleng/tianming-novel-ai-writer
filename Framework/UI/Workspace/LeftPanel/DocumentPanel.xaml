<UserControl x:Class="TM.Framework.UI.Workspace.LeftPanel.DocumentPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:chapterlist="clr-namespace:TM.Framework.UI.Workspace.LeftPanel.ChapterList">

    <Border Background="Transparent"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource SmallRadius}"
            Margin="1,0">
        <DockPanel>

            <Border DockPanel.Dock="Top"
                    Background="{DynamicResource SurfaceGlass}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="6,6,6,6"
                    Height="30">
                <TextBlock Text="文档管理区"
                           FontSize="12"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"/>
            </Border>

            <Border Background="{DynamicResource ContentBackgroundGlass}"
                    CornerRadius="0,0,6,6">
                <chapterlist:ChapterListPanel x:Name="ChapterList"/>
            </Border>
        </DockPanel>
    </Border>
</UserControl>
