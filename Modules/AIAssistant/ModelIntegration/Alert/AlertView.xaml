<UserControl x:Class="TM.Modules.AIAssistant.ModelIntegration.Alert.AlertView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:layout="clr-namespace:TM.Framework.Common.Controls.Layout">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Image Source="{DynamicResource Icon.Bell}" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="API告警"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="重新加载"
                            Command="{Binding ReloadCommand}"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Margin="0,0,8,0"/>
                    <Button Content="测试发送"
                            Command="{Binding TestSendCommand}"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Margin="0,0,8,0"/>
                    <Button Content="保存配置"
                            Command="{Binding SaveCommand}"
                            Style="{DynamicResource PrimaryButtonStyle}"/>
                </StackPanel>
            </Grid>

            <layout:IconHeaderGroupBox Icon="{DynamicResource Icon.Settings}" Title="总开关" Margin="0,0,0,15">
                <StackPanel>
                    <CheckBox Content="启用 API 告警（关闭后不会监控也不会发送任何通知）"
                              IsChecked="{Binding Enabled}"
                              Margin="0,0,0,5"/>
                    <TextBlock Text="启用后，系统会监控所有 AI API 调用，根据下方触发策略与渠道配置发送告警。"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondary}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Icon="{DynamicResource Icon.Warning}" Title="触发策略" Margin="0,0,0,15">
                <StackPanel>
                    <CheckBox Content="任意 API 调用失败立即触发"
                              IsChecked="{Binding OnAnyError}"
                              Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <CheckBox Content="同一模型连续失败"
                                  IsChecked="{Binding OnConsecutiveFailures}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,8,0"/>
                        <TextBox Text="{Binding ConsecutiveFailureThreshold, UpdateSourceTrigger=PropertyChanged}"
                                 Width="60"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,8,0"/>
                        <TextBlock Text="次后触发"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <CheckBox Content="任务被中止/取消/超时时触发"
                              IsChecked="{Binding OnTaskAborted}"
                              Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="冷却时间（分钟）："
                                   VerticalAlignment="Center"
                                   Width="120"/>
                        <TextBox Text="{Binding CooldownMinutes, UpdateSourceTrigger=PropertyChanged}"
                                 Width="80"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,8,0"/>
                        <TextBlock Text="同一类型告警在该时间内只发送一次（0 表示不冷却，可能频繁发送）"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondary}"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Icon="{DynamicResource Icon.Bell}" Title="邮件渠道" Margin="0,0,0,15">
                <StackPanel>
                    <CheckBox Content="启用邮件渠道"
                              IsChecked="{Binding EmailEnabled}"
                              Margin="0,0,0,12"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="SMTP 服务器:" VerticalAlignment="Center" Width="120"/>
                        <TextBox Text="{Binding SmtpHost, UpdateSourceTrigger=PropertyChanged}"
                                 Width="300"
                                 VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="端口:" VerticalAlignment="Center" Width="120"/>
                        <TextBox Text="{Binding SmtpPort, UpdateSourceTrigger=PropertyChanged}"
                                 Width="100"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,12,0"/>
                        <CheckBox Content="启用 SSL"
                                  IsChecked="{Binding EnableSsl}"
                                  VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="发件邮箱:" VerticalAlignment="Center" Width="120"/>
                        <TextBox Text="{Binding SenderEmail, UpdateSourceTrigger=PropertyChanged}"
                                 Width="300"
                                 VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="发件人显示名:" VerticalAlignment="Center" Width="120"/>
                        <TextBox Text="{Binding SenderDisplayName, UpdateSourceTrigger=PropertyChanged}"
                                 Width="300"
                                 VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="授权码/密码:" VerticalAlignment="Center" Width="120"/>
                        <PasswordBox x:Name="AuthCodePasswordBox"
                                     Width="300"
                                     VerticalContentAlignment="Center"
                                     Loaded="AuthCodePasswordBox_Loaded"
                                     PasswordChanged="AuthCodePasswordBox_PasswordChanged"/>
                    </StackPanel>

                    <TextBlock Text="提示：QQ/163/Outlook 等邮箱需在邮箱网页端先开启 SMTP 服务并获取“授权码”，此处填写授权码而非登录密码。"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondary}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"/>

                    <StackPanel Margin="0,0,0,5">
                        <TextBlock Text="收件人列表（多个邮箱用逗号或分号分隔）:"
                                   Margin="0,0,0,5"/>
                        <TextBox Text="{Binding RecipientsText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="60"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                </StackPanel>
            </layout:IconHeaderGroupBox>

        </StackPanel>
    </ScrollViewer>

</UserControl>
