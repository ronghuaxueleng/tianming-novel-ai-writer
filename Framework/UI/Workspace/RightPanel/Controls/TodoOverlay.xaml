<UserControl x:Class="TM.Framework.UI.Workspace.RightPanel.Controls.TodoOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="{DynamicResource DialogGlass}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            VerticalAlignment="Top"
            MaxHeight="300">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="25"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource SurfaceGlass}"
                    CornerRadius="8,8,0,0"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="12,0">
                <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="{Binding TitleIcon}" Width="12" Height="12" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding CurrentStatusTitle}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="12,0,12,0"
                           TextTrimming="CharacterEllipsis"/>

                <TextBlock Grid.Column="2"
                           Text="{Binding ProgressText}"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"/>

                <Border Grid.Column="3"
                        CornerRadius="4"
                        Padding="12,5"
                        Margin="0,0,8,0"
                        MouseLeftButtonDown="OnBackToPlanClick">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource GlassBorderBrush}"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CanBackToPlan}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource DangerColor}"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="回溯计划"
                               FontSize="11"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource TextDisabled}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CanBackToPlan}" Value="True">
                                        <Setter Property="Foreground" Value="Black"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>

                <Button Grid.Column="4"
                        Width="20" Height="20"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="关闭"
                        Click="OnCloseClick">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
                                <Rectangle x:Name="CloseIcon" Width="10" Height="10"
                                           Fill="{DynamicResource TextSecondary}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="{DynamicResource Icon.Close}" Stretch="Uniform"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DangerColor}"/>
                                    <Setter TargetName="CloseIcon" Property="Fill" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                </Grid>
            </Border>

            <ScrollViewer x:Name="StepsScrollViewer"
                          Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          MaxHeight="220"
                          Margin="8,4,8,8">
                <ItemsControl ItemsSource="{Binding Steps}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource ContentBackgroundGlass}"
                                    BorderBrush="{DynamicResource GlassBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8,6"
                                    Margin="0,0,0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0">

                                        <Image Source="{Binding StatusIcon}"
                                                         Width="11" Height="11"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"
                                                         Visibility="{Binding IsRunning, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                                        <Border RenderTransformOrigin="0.5,0.5"
                                                Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <Border.RenderTransform>
                                                <RotateTransform x:Name="SpinTransform"/>
                                            </Border.RenderTransform>
                                            <Border.Triggers>
                                                <EventTrigger RoutedEvent="Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="SpinTransform"
                                                                             Storyboard.TargetProperty="Angle"
                                                                             From="0" To="360"
                                                                             Duration="0:0:1"
                                                                             RepeatBehavior="Forever"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Border.Triggers>
                                            <Image Source="{DynamicResource Icon.Refresh}" Width="11" Height="11"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding ToolName}"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding StatusText}"
                                               Foreground="{DynamicResource TextTertiary}"
                                               FontSize="11"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
