<UserControl x:Class="TM.Framework.UI.Workspace.CenterPanel.Controls.DiffViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:diffplex="clr-namespace:DiffPlex.Wpf.Controls;assembly=DiffPlex.Wpf">

    <Border Background="{DynamicResource ContentBackgroundGlass}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            ClipToBounds="True">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource SurfaceGlass}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="12,8">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <TextBlock Text="{Binding Title}"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextPrimary}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <TextBlock Text="{Binding DiffSummary}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextTertiary}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Border Grid.Row="1"
                    Background="{DynamicResource Surface}"
                    Padding="12,6"
                    Visibility="{Binding FilePathVisibility}">
                <TextBlock Text="{Binding FilePath}"
                           FontSize="11"
                           Foreground="{DynamicResource TextSecondary}"
                           FontFamily="Consolas, Courier New, monospace"/>
            </Border>

            <diffplex:DiffViewer Grid.Row="2"
                                 x:Name="DiffPlexViewer"
                                 OldText="{Binding OriginalContent}"
                                 NewText="{Binding ModifiedContent}"
                                 IsSideBySide="False"
                                 FontSize="13"
                                 FontFamily="Consolas, Microsoft YaHei UI, monospace"
                                 IsCommandBarVisible="False">

                <diffplex:DiffViewer.InsertedBackground>
                    <SolidColorBrush Color="#2D2EA043"/>
                </diffplex:DiffViewer.InsertedBackground>
                <diffplex:DiffViewer.InsertedForeground>
                    <SolidColorBrush Color="#B5E4A0"/>
                </diffplex:DiffViewer.InsertedForeground>
                <diffplex:DiffViewer.DeletedBackground>
                    <SolidColorBrush Color="#30D83232"/>
                </diffplex:DiffViewer.DeletedBackground>
                <diffplex:DiffViewer.DeletedForeground>
                    <SolidColorBrush Color="#E4A0A0"/>
                </diffplex:DiffViewer.DeletedForeground>
                <diffplex:DiffViewer.UnchangedForeground>
                    <SolidColorBrush Color="#C8C8C8"/>
                </diffplex:DiffViewer.UnchangedForeground>
                <diffplex:DiffViewer.UnchangedBackground>
                    <SolidColorBrush Color="#1E1E2E"/>
                </diffplex:DiffViewer.UnchangedBackground>
                <diffplex:DiffViewer.ImaginaryBackground>
                    <SolidColorBrush Color="#14808080"/>
                </diffplex:DiffViewer.ImaginaryBackground>
                <diffplex:DiffViewer.Foreground>
                    <SolidColorBrush Color="#D4D4D4"/>
                </diffplex:DiffViewer.Foreground>
                <diffplex:DiffViewer.Background>
                    <SolidColorBrush Color="#1E1E2E"/>
                </diffplex:DiffViewer.Background>
                <diffplex:DiffViewer.HeaderForeground>
                    <SolidColorBrush Color="#888888"/>
                </diffplex:DiffViewer.HeaderForeground>
                <diffplex:DiffViewer.HeaderBackground>
                    <SolidColorBrush Color="#252535"/>
                </diffplex:DiffViewer.HeaderBackground>
            </diffplex:DiffViewer>

            <Border Grid.Row="3"
                    Background="{DynamicResource SurfaceGlass}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="12,8">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="放弃"
                            Command="{Binding RejectCommand}"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Margin="0,0,8,0"
                            Padding="16,6"/>
                    <Button Content="采纳修改"
                            Command="{Binding AcceptCommand}"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Padding="16,6"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
