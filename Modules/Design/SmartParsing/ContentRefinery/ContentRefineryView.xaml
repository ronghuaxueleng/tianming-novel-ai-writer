<UserControl x:Class="TM.Modules.Design.SmartParsing.ContentRefinery.ContentRefineryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dm="clr-namespace:TM.Framework.Common.Controls.DataManagement"
             xmlns:layout="clr-namespace:TM.Framework.Common.Controls.Layout">

    <dm:TwoColumnEditorLayout
        LeftIcon="{DynamicResource Icon.Sparkle}"
        LeftTitle="提炼分析"
        RightIcon="{DynamicResource Icon.Sparkle}"
        RightTitle="内容提炼"
        ItemsSource="{Binding TreeData}"
        ShowSearch="True"
        SearchKeyword="{Binding SearchKeyword, Mode=TwoWay}"
        NodeDoubleClickCommand="{Binding SelectNodeCommand}"
        AddCommand="{Binding AddCommand}"
        SaveCommand="{Binding SaveCommand}"
        DeleteCommand="{Binding DeleteCommand}"
        DeleteAllCommand="{Binding DeleteAllCommand}"
        TreeAfterActionCommand="{Binding TreeAfterActionCommand}"
        AIGenerateCommand="{Binding AIGenerateCommand}"
        IsAIGenerateEnabled="{Binding IsAIGenerateEnabled}"
        SelectedHeaderTabIndex="{Binding SelectedTabIndex, Mode=TwoWay}"
        UseStandardScheme2Layout="True"
        Tab1Header="内容上传"
        Tab2Header="提炼预览"
        Tab3Header="提炼历史">

        <dm:TwoColumnEditorLayout.EditAdditionalContent>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <layout:IconHeaderGroupBox Grid.Row="0" Icon="{DynamicResource Icon.Target}" Title="提炼目标" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="目标模块：" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="14"/>
                        <TextBlock Grid.Column="1" Text="{Binding SelectedModuleDisplayName}" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimary}" FontSize="14" FontWeight="SemiBold"/>

                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                    Visibility="{Binding HasRequiredInputs, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="总卷数：" VerticalAlignment="Center" Margin="20,0,5,0"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="14"/>
                            <TextBox Text="{Binding PrerequisiteValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource StandardTextBoxStyle}" Width="80" Height="36"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Command="{Binding UploadFileCommand}" Margin="0,0,10,0"
                                    Style="{DynamicResource SecondaryButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{DynamicResource Icon.FolderOpen}" Width="14" Height="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="选择文件"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ClearCommand}"
                                    Style="{DynamicResource SecondaryButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{DynamicResource Icon.Trash}" Width="14" Height="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="清空"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </layout:IconHeaderGroupBox>

                <layout:IconHeaderGroupBox Grid.Row="1" Icon="{DynamicResource Icon.Edit}" Title="原始内容">
                    <TextBox Text="{Binding RawContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True" AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto"
                             Height="Auto" VerticalAlignment="Stretch"
                             BorderThickness="0" Background="Transparent"
                             Foreground="{DynamicResource TextPrimary}"
                             FontSize="14"/>
                </layout:IconHeaderGroupBox>
            </Grid>
        </dm:TwoColumnEditorLayout.EditAdditionalContent>

        <dm:TwoColumnEditorLayout.DetailsContent>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <layout:IconHeaderGroupBox Grid.Row="0" Icon="{DynamicResource Icon.Clipboard}" Title="提炼结果" Margin="0,0,0,10">
                    <Grid Background="Transparent">

                        <ListBox ItemsSource="{Binding RefineryResults}"
                                 Visibility="{Binding RefineryResults.Count, Converter={StaticResource CountToVisibilityConverter}}"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 Background="Transparent" BorderThickness="0">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Focusable" Value="False"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10" CornerRadius="8"
                                                Background="Transparent"
                                                BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                                                SnapsToDevicePixels="True">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="4"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0" CornerRadius="8,0,0,8">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{DynamicResource SuccessColor}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsValid}" Value="False">
                                                                    <Setter Property="Background" Value="{DynamicResource DangerColor}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                </Border>

                                                <StackPanel Grid.Column="1" Margin="12,10,12,10">

                                                    <Grid Margin="0,0,0,6">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextPrimary}"
                                                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                        <Border Grid.Column="1" CornerRadius="4" Padding="6,2">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="{DynamicResource SuccessColor}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsValid}" Value="False">
                                                                            <Setter Property="Background" Value="{DynamicResource DangerColor}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock FontSize="11" Foreground="White">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text" Value="有效"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsValid}" Value="False">
                                                                                <Setter Property="Text" Value="无效"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>
                                                    </Grid>

                                                    <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,0,0,6"/>

                                                    <ItemsControl ItemsSource="{Binding DisplayFields}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Margin="0,0,0,3">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0" Text="{Binding Key}" FontSize="12"
                                                                               Foreground="{DynamicResource TextTertiary}" Margin="0,0,6,0"/>
                                                                    <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="12"
                                                                               Foreground="{DynamicResource TextSecondary}"
                                                                               TextTrimming="CharacterEllipsis"/>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding RefineryResults.Count, Converter={StaticResource InverseCountToVisibilityConverter}}">
                            <Image Source="{DynamicResource Icon.Clipboard}" Width="40" Height="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="暂无提炼结果" FontSize="16" Foreground="{DynamicResource TextTertiary}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="请在「内容上传」Tab输入内容后点击AI提炼" FontSize="13"
                                       Foreground="{DynamicResource TextDisabled}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>
                </layout:IconHeaderGroupBox>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding CommitCommand}" Margin="0,0,10,0"
                            Style="{DynamicResource PrimaryButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{DynamicResource Icon.Save}" Width="14" Height="14" Margin="0,0,5,0"/>
                            <TextBlock Text="确认落盘"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ClearCommand}"
                            Style="{DynamicResource SecondaryButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{DynamicResource Icon.Trash}" Width="14" Height="14" Margin="0,0,5,0"/>
                            <TextBlock Text="清空"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </dm:TwoColumnEditorLayout.DetailsContent>

        <dm:TwoColumnEditorLayout.Tab3Content>
            <DockPanel LastChildFill="True">

                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Command="{Binding ClearHistoryCommand}"
                            Style="{DynamicResource DangerButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{DynamicResource Icon.Trash}" Width="14" Height="14" Margin="0,0,5,0"/>
                            <TextBlock Text="清空历史"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="5,0,0,8">
                    <Image Source="{DynamicResource Icon.Scroll}" Width="14" Height="14" Margin="0,0,5,0"/>
                    <TextBlock Text="提炼历史" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>

                <Grid>

                        <ListBox ItemsSource="{Binding HistoryRecords}"
                                 Visibility="{Binding HistoryRecords.Count, Converter={StaticResource CountToVisibilityConverter}}"
                                 BorderThickness="0" Background="Transparent"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                 VirtualizingPanel.ScrollUnit="Pixel"
                                 ScrollViewer.CanContentScroll="True"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 HorizontalContentAlignment="Stretch">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,6" CornerRadius="8"
                                            Background="Transparent"
                                            BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1">
                                        <StackPanel>

                                                <Border Padding="12,10" CornerRadius="8" Cursor="Hand">
                                                    <Border.InputBindings>
                                                        <MouseBinding MouseAction="LeftClick"
                                                                      Command="{Binding DataContext.ToggleHistoryExpandCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                      CommandParameter="{Binding}"/>
                                                    </Border.InputBindings>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Image Grid.Column="0" Source="{DynamicResource Icon.Scroll}" Width="15" Height="15"
                                                                         VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock FontSize="14" FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource TextPrimary}">
                                                                <Run Text="{Binding TargetModuleDisplayName, Mode=OneWay}"/>
                                                                <Run Text=" · "/>
                                                                <Run Text="{Binding ResultCount}"/>
                                                                <Run Text=" 条"/>
                                                            </TextBlock>
                                                            <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:MM-dd HH:mm}'}"
                                                                       FontSize="12" Margin="0,2,0,0"
                                                                       Foreground="{DynamicResource TextTertiary}"/>
                                                        </StackPanel>
                                                        <Border Grid.Column="2" CornerRadius="4" Padding="6,2"
                                                                VerticalAlignment="Center" Margin="0,0,8,0">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="{DynamicResource SuccessColor}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsCommitted}" Value="False">
                                                                            <Setter Property="Background" Value="{DynamicResource WarningColor}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock FontSize="11" Foreground="White">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text" Value="已落盘"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsCommitted}" Value="False">
                                                                                <Setter Property="Text" Value="未落盘"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>
                                                        <TextBlock Grid.Column="3" VerticalAlignment="Center"
                                                                   FontSize="12" Foreground="{DynamicResource TextTertiary}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="▼"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                            <Setter Property="Text" Value="▲"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                </Border>

                                                <Border Padding="12,0,12,12" CornerRadius="0,0,8,8"
                                                        Background="Transparent" MaxHeight="250">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                                                        <TextBlock FontSize="12"
                                                                   TextWrapping="Wrap"
                                                                   Foreground="{DynamicResource TextSecondary}"
                                                                   Margin="0,8,0,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="{Binding ResultsSummary}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ResultsSummary}" Value="">
                                                                            <Setter Property="Text" Value="{Binding RawContentPreview}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </ScrollViewer>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Visibility="{Binding HistoryRecords.Count, Converter={StaticResource InverseCountToVisibilityConverter}}">
                                <Image Source="{DynamicResource Icon.Clipboard}" Width="40" Height="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <TextBlock Text="暂无提炼历史" FontSize="16" Foreground="{DynamicResource TextTertiary}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
            </DockPanel>
        </dm:TwoColumnEditorLayout.Tab3Content>

    </dm:TwoColumnEditorLayout>

</UserControl>
