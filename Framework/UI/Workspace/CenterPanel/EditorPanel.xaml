<UserControl x:Class="TM.Framework.UI.Workspace.CenterPanel.EditorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:chaptereditor="clr-namespace:TM.Framework.UI.Workspace.CenterPanel.ChapterEditor"
             xmlns:controls="clr-namespace:TM.Framework.UI.Workspace.CenterPanel.Controls">

    <Border Background="Transparent"
            BorderBrush="Transparent"
            BorderThickness="0"
            CornerRadius="{StaticResource SmallRadius}"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource SurfaceGlass}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6,6,0,0"
                    Height="30">
                <chaptereditor:EditorTabBar x:Name="EditorTabBar"/>
            </Border>

            <Border Grid.Row="1"
                    Background="Transparent"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1,0,1,1"
                    CornerRadius="0,0,6,6"
                    ClipToBounds="True">
                <Grid>

                    <chaptereditor:DashboardView x:Name="DashboardPanel" Visibility="Collapsed"/>

                    <Border Visibility="{Binding Visibility, ElementName=ChapterEditor}" Background="{DynamicResource ContentBackgroundGlass}">
                        <chaptereditor:ChapterMarkdownEditor x:Name="ChapterEditor" Visibility="Collapsed"/>
                    </Border>

                    <Border Visibility="{Binding Visibility, ElementName=DiffViewerPanel}" Background="{DynamicResource ContentBackgroundGlass}" Margin="8" CornerRadius="8">
                        <controls:DiffViewer x:Name="DiffViewerPanel" Visibility="Collapsed"/>
                    </Border>

                    <Border Visibility="{Binding Visibility, ElementName=PlanViewPanel}" Background="{DynamicResource ContentBackgroundGlass}">
                        <chaptereditor:PlanView x:Name="PlanViewPanel" Visibility="Collapsed"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
