<UserControl x:Class="TM.Framework.Common.Controls.DataTreeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:TM.Framework.Common.Helpers.UI"
             xmlns:local="clr-namespace:TM.Framework.Common.Controls"
             xmlns:animations="clr-namespace:TM.Framework.Common.Controls.Animations">

    <UserControl.Resources>
        <ResourceDictionary>

            <local:TreeNodeCountVisibilityConverter x:Key="TreeNodeCountVisibilityConverter"/>

            <local:TagIsDeletableVisibilityConverter x:Key="TagIsDeletableVisibilityConverter"/>

            <SolidColorBrush x:Key="TreeHighlightBluePulse" Color="#FF7CB4FF"/>
            <SolidColorBrush x:Key="TreeHighlightGreenPulse" Color="#FF8CF8BC"/>

            <Style x:Key="NodeNameTextStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{DynamicResource GlobalFontFamily}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                <Style.Triggers>

                    <DataTrigger Binding="{Binding IsSiblingBranch}" Value="True">
                        <Setter Property="Foreground" Value="{Binding NameBrush}"/>
                    </DataTrigger>

                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                        <Setter Property="Foreground" Value="{Binding NameBrush}"/>
                    </DataTrigger>

                    <DataTrigger Binding="{Binding IsSelectionFocus}" Value="True">
                        <Setter Property="Foreground" Value="{Binding NameBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="LevelBadgeTextStyle" TargetType="TextBlock">
                <Setter Property="Visibility" Value="Visible"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin" Value="3,0,6,0"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="TextAlignment" Value="Center"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Level}" Value="0">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="NodeButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Padding" Value="3,6,12,6"/>
                <Setter Property="Margin" Value="0,3"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid x:Name="LeftContainer"
                                          Grid.Column="0"
                                          Width="0"
                                          Margin="0"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Stretch"
                                          ClipToBounds="True">
                                        <animations:AnimatedGradientStripe x:Name="LeftStatic"
                                                                           Orientation="Vertical"
                                                                           Thickness="5"
                                                                           BaseBrush="{DynamicResource PrimaryColor}"
                                                                           PulseBrush="{StaticResource TreeHighlightBluePulse}"
                                                                           StripeCornerRadius="6,0,0,6"
                                                                           Visibility="Collapsed"
                                                                           IsActive="False"
                                                                           AnimationDuration="0:0:2.0"/>
                                        <animations:AnimatedGradientStripe x:Name="LeftAnimated"
                                                                           Orientation="Vertical"
                                                                           Thickness="5"
                                                                           BaseBrush="{DynamicResource SuccessColor}"
                                                                           PulseBrush="{StaticResource TreeHighlightGreenPulse}"
                                                                           StripeCornerRadius="6,0,0,6"
                                                                           Visibility="Collapsed"
                                                                           IsActive="False"
                                                                           AnimationDuration="0:0:1.4"/>
                                        <animations:AnimatedGradientStripe x:Name="LeftSibling"
                                                                           Orientation="Vertical"
                                                                           Thickness="5"
                                                                           BaseBrush="{DynamicResource TextTertiary}"
                                                                           PulseBrush="{DynamicResource TextSecondary}"
                                                                           StripeCornerRadius="6,0,0,6"
                                                                           Visibility="Collapsed"
                                                                           IsActive="False"
                                                                           AnimationDuration="0:0:1.8"/>
                                    </Grid>

                                    <ContentPresenter Grid.Column="1"
                                                      Margin="{TemplateBinding Padding}"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>

                                    <Polygon x:Name="UserDeletableCorner"
                                             Points="0,0 0,5 5,0"
                                             Fill="{DynamicResource WarningColor}"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Top"
                                             Margin="0"
                                             IsHitTestVisible="False"
                                             Panel.ZIndex="10"
                                             Visibility="{Binding Converter={StaticResource TagIsDeletableVisibilityConverter}}">
                                        <Polygon.ToolTip>
                                            <ToolTip Content="用户自建" />
                                        </Polygon.ToolTip>
                                    </Polygon>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="{DynamicResource HoverBackground}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="{DynamicResource GlassBorderBrush}"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=(helpers:ButtonHelper.IsSelected)}" Value="True">
                                    <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource PrimaryColor}"/>
                                    <Setter TargetName="Border" Property="BorderThickness" Value="2"/>
                                    <Setter TargetName="LeftContainer" Property="Width" Value="5"/>
                                    <Setter TargetName="LeftStatic" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="LeftStatic" Property="IsActive" Value="True"/>
                                    <Setter TargetName="UserDeletableCorner" Property="Margin" Value="5,0,0,0"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsSelectionFocus}" Value="True">
                                    <Setter TargetName="LeftContainer" Property="Width" Value="5"/>
                                    <Setter TargetName="LeftStatic" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="LeftStatic" Property="IsActive" Value="False"/>
                                    <Setter TargetName="LeftSibling" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="LeftSibling" Property="IsActive" Value="False"/>
                                    <Setter TargetName="LeftAnimated" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="LeftAnimated" Property="IsActive" Value="True"/>
                                    <Setter TargetName="Border" Property="BorderBrush" Value="#FF39B86D"/>
                                    <Setter TargetName="Border" Property="BorderThickness" Value="2"/>
                                    <Setter TargetName="UserDeletableCorner" Property="Margin" Value="5,0,0,0"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsSiblingBranch}" Value="True">
                                    <Setter TargetName="LeftContainer" Property="Width" Value="5"/>
                                    <Setter TargetName="LeftStatic" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="LeftStatic" Property="IsActive" Value="False"/>
                                    <Setter TargetName="LeftAnimated" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="LeftAnimated" Property="IsActive" Value="False"/>
                                    <Setter TargetName="LeftSibling" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="LeftSibling" Property="IsActive" Value="True"/>
                                    <Setter TargetName="UserDeletableCorner" Property="Margin" Value="5,0,0,0"/>
                                </DataTrigger>

                                <DataTrigger Binding="{Binding IsDragging}" Value="True">
                                    <Setter TargetName="Border" Property="BorderBrush" Value="#FFFFA500"/>
                                    <Setter TargetName="Border" Property="BorderThickness" Value="2"/>
                                    <Setter TargetName="Border" Property="Opacity" Value="0.7"/>
                                </DataTrigger>

                                <DataTrigger Binding="{Binding IsDragOver}" Value="True">
                                    <Setter TargetName="Border" Property="BorderBrush" Value="#FF39B86D"/>
                                    <Setter TargetName="Border" Property="BorderThickness" Value="2"/>
                                    <Setter TargetName="Border" Property="Background" Value="#1039B86D"/>
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="Level1NodeButtonStyle" TargetType="Button" BasedOn="{StaticResource NodeButtonStyle}">
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Margin" Value="0,5,0,2"/>
            </Style>

            <DataTemplate x:Key="FullNodeTemplate">
                <Button x:Name="NodeButton"
                        Command="{Binding InternalParentNodeClickCommand, RelativeSource={RelativeSource AncestorType=local:DataTreeView}}"
                        CommandParameter="{Binding}"
                        helpers:ButtonHelper.IsSelected="{Binding IsSelected}"
                        AllowDrop="True"
                        PreviewMouseLeftButtonDown="OnNodePreviewMouseLeftButtonDown"
                        PreviewMouseLeftButtonUp="OnNodePreviewMouseLeftButtonUp"
                        PreviewMouseMove="OnNodePreviewMouseMove"
                        DragEnter="OnNodeDragEnter"
                        DragLeave="OnNodeDragLeave"
                        Drop="OnNodeDrop"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource NodeButtonStyle}">
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="FontWeight" Value="Normal"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                            <Setter Property="Padding" Value="3,6"/>
                        </Style>
                    </Button.Style>
                    <DockPanel>
                        <Border DockPanel.Dock="Right"
                                Background="Transparent"
                                BorderBrush="{DynamicResource SuccessColor}"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="4,1"
                                Margin="0,0,0,-3"
                                VerticalAlignment="Bottom"
                                HorizontalAlignment="Right"
                                Visibility="{Binding HasStatusBadge, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="{DynamicResource Icon.Check}" Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,2,0"/>
                                <TextBlock Text="{Binding StatusBadge}" Foreground="{DynamicResource SuccessColor}" FontSize="10" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Level, StringFormat='Lv{0}'}"
                                       Foreground="{Binding LevelBrush}"
                                       Style="{StaticResource LevelBadgeTextStyle}"
                                       Visibility="{Binding ShowLevelIndicator, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <Image x:Name="LogoImg" Source="{Binding LogoImage}" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"
                                   Visibility="{Binding HasLogoImage, Converter={StaticResource BoolToVisibilityConverter}}"/>

                            <Image Source="{Binding Icon}" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"
                                   Visibility="{Binding ShowIcon, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Style="{StaticResource NodeNameTextStyle}"/>
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextTertiary}"
                                       FontSize="12"
                                       Margin="10,0,0,0"
                                       Text="{Binding Children.Count, StringFormat=' ({0})'}">
                                <TextBlock.Visibility>
                                    <MultiBinding Converter="{StaticResource TreeNodeCountVisibilityConverter}">
                                        <Binding Path="ShowChildCount"/>
                                        <Binding Path="IsFileSystemNode"/>
                                        <Binding Path="Children.Count"/>
                                    </MultiBinding>
                                </TextBlock.Visibility>
                            </TextBlock>
                        </StackPanel>
                    </DockPanel>
                </Button>
                <DataTemplate.Triggers>
                    <DataTrigger Binding="{Binding Level}" Value="1">
                        <Setter TargetName="NodeButton" Property="FontSize" Value="14"/>
                        <Setter TargetName="NodeButton" Property="FontWeight" Value="Bold"/>
                        <Setter TargetName="NodeButton" Property="Margin" Value="0,5,0,2"/>
                        <Setter TargetName="LogoImg" Property="Width" Value="16"/>
                        <Setter TargetName="LogoImg" Property="Height" Value="16"/>
                        <Setter TargetName="LogoImg" Property="Margin" Value="0,0,8,0"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Level}" Value="2">
                        <Setter TargetName="NodeButton" Property="Margin" Value="10,0,0,0"/>
                    </DataTrigger>
                </DataTemplate.Triggers>
            </DataTemplate>

            <DataTemplate x:Key="LeafNodeTemplate">
                <Button Command="{Binding InternalParentNodeClickCommand, RelativeSource={RelativeSource AncestorType=local:DataTreeView}}"
                        CommandParameter="{Binding}"
                        helpers:ButtonHelper.IsSelected="{Binding IsSelected}"
                        AllowDrop="True"
                        PreviewMouseLeftButtonDown="OnNodePreviewMouseLeftButtonDown"
                        PreviewMouseLeftButtonUp="OnNodePreviewMouseLeftButtonUp"
                        PreviewMouseMove="OnNodePreviewMouseMove"
                        DragEnter="OnNodeDragEnter"
                        DragLeave="OnNodeDragLeave"
                        Drop="OnNodeDrop"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource NodeButtonStyle}">
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="FontWeight" Value="Normal"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                            <Setter Property="Padding" Value="3,6"/>
                            <Setter Property="Margin" Value="20,3,0,3"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Level}" Value="4">
                                    <Setter Property="Margin" Value="30,3,0,3"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Level}" Value="5">
                                    <Setter Property="Margin" Value="40,3,0,3"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <DockPanel>
                        <Border DockPanel.Dock="Right"
                                Background="Transparent"
                                BorderBrush="{DynamicResource SuccessColor}"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="4,1"
                                Margin="0,0,0,-3"
                                VerticalAlignment="Bottom"
                                HorizontalAlignment="Right"
                                Visibility="{Binding HasStatusBadge, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="{DynamicResource Icon.Check}" Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,2,0"/>
                                <TextBlock Text="{Binding StatusBadge}" Foreground="{DynamicResource SuccessColor}" FontSize="10" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Level, StringFormat='Lv{0}'}"
                                       Foreground="{Binding LevelBrush}"
                                       Style="{StaticResource LevelBadgeTextStyle}"
                                       Visibility="{Binding ShowLevelIndicator, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <Image Source="{Binding LogoImage}" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"
                                   Visibility="{Binding HasLogoImage, Converter={StaticResource BoolToVisibilityConverter}}"/>

                            <Image Source="{Binding Icon}" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"
                                   Visibility="{Binding ShowIcon, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Style="{StaticResource NodeNameTextStyle}"/>
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextTertiary}"
                                       FontSize="12"
                                       Margin="10,0,0,0"
                                       Text="{Binding Children.Count, StringFormat=' ({0})'}">
                                <TextBlock.Visibility>
                                    <MultiBinding Converter="{StaticResource TreeNodeCountVisibilityConverter}">
                                        <Binding Path="ShowChildCount"/>
                                        <Binding Path="IsFileSystemNode"/>
                                        <Binding Path="Children.Count"/>
                                    </MultiBinding>
                                </TextBlock.Visibility>
                            </TextBlock>
                        </StackPanel>
                    </DockPanel>
                </Button>
            </DataTemplate>

            <local:TreeNodeTemplateSelector x:Key="NodeTemplateSelector"
                                            ParentTemplate="{StaticResource FullNodeTemplate}"
                                            LeafTemplate="{StaticResource LeafNodeTemplate}"/>

        </ResourceDictionary>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListBox Grid.Row="0"
                 x:Name="RootItemsControl"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.CanContentScroll="True"
                 VirtualizingStackPanel.IsVirtualizing="True"
                 VirtualizingStackPanel.VirtualizationMode="Recycling"
                 VirtualizingPanel.ScrollUnit="Pixel"
                 VirtualizingPanel.CacheLength="1,2"
                 VirtualizingPanel.CacheLengthUnit="Page"
                 BorderThickness="0"
                 Background="Transparent"
                 IsHitTestVisible="True"
                 Focusable="False"
                 ContextMenu="{Binding NodeContextMenu, RelativeSource={RelativeSource AncestorType=local:DataTreeView}}"
                 PreviewMouseRightButtonDown="OnRootItemsRightButtonDown">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplateSelector>
                <StaticResource ResourceKey="NodeTemplateSelector"/>
            </ListBox.ItemTemplateSelector>
        </ListBox>

        <Grid Grid.Row="1"
              Margin="0,10,0,0"
              HorizontalAlignment="Stretch"
              x:Name="ActionButtonPanel">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Style>
            </Grid.Style>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="DeleteAllButton"
                    Grid.Row="0" Grid.Column="0"
                    Margin="0,0,3,5"
                    Style="{StaticResource DangerButtonStyle}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Command="{Binding InternalDeleteAllCommand, RelativeSource={RelativeSource AncestorType=local:DataTreeView}}"
                    ToolTipService.ShowOnDisabled="True">
                <StackPanel Orientation="Horizontal">
                    <Image Source="{DynamicResource Icon.Trash}" Width="11" Height="11" Margin="0,0,2,0" VerticalAlignment="Center"/>
                    <TextBlock Text="全部删除" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button x:Name="DeleteButton"
                    Grid.Row="0" Grid.Column="1"
                    Margin="3,0,3,5"
                    Style="{StaticResource DangerButtonStyle}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Command="{Binding InternalDeleteCommand, RelativeSource={RelativeSource AncestorType=local:DataTreeView}}"
                    ToolTipService.ShowOnDisabled="True">
                <StackPanel Orientation="Horizontal">
                    <Image Source="{DynamicResource Icon.Trash}" Width="11" Height="11" Margin="0,0,2,0" VerticalAlignment="Center"/>
                    <TextBlock Text="删除" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button x:Name="AIGenerateButton"
                    Grid.Row="0" Grid.Column="2"
                    Margin="3,0,0,5"
                    Style="{StaticResource PrimaryButtonStyle}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Visibility="Collapsed"
                    Command="{Binding AIGenerateCommand, RelativeSource={RelativeSource AncestorType=local:DataTreeView}}"
                    ToolTipService.ShowOnDisabled="True">
                <StackPanel Orientation="Horizontal">
                    <Image Source="{DynamicResource Icon.Sparkle}" Width="11" Height="11" Margin="0,0,2,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding AIGenerateButtonText, RelativeSource={RelativeSource AncestorType=local:DataTreeView}}" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Grid.Row="1" Grid.Column="0"
                    Margin="0,0,3,0"
                    IsEnabled="{Binding IsBulkToggleEnabled, RelativeSource={RelativeSource AncestorType=local:DataTreeView}}"
                    Command="{Binding InternalBulkToggleCommand, RelativeSource={RelativeSource AncestorType=local:DataTreeView}}"
                    ToolTip="{Binding BulkToggleToolTip, RelativeSource={RelativeSource AncestorType=local:DataTreeView}}"
                    ToolTipService.ShowOnDisabled="True"
                    Style="{StaticResource PrimaryButtonStyle}">
                <StackPanel Orientation="Horizontal">
                    <Image Source="{DynamicResource Icon.Lightning}" Width="11" Height="11" Margin="0,0,2,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding BulkToggleButtonText, RelativeSource={RelativeSource AncestorType=local:DataTreeView}}"
                               FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button x:Name="AddButton"
                    Grid.Row="1" Grid.Column="1"
                    Margin="3,0,3,0"
                    Style="{StaticResource PrimaryButtonStyle}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Command="{Binding InternalAddCommand, RelativeSource={RelativeSource AncestorType=local:DataTreeView}}"
                    ToolTipService.ShowOnDisabled="True">
                <StackPanel Orientation="Horizontal">
                    <Image x:Name="AddButtonIcon" Source="{DynamicResource Icon.Plus}" Width="11" Height="11" Margin="0,0,2,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="AddButtonText" Text="新建" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button x:Name="SaveButton"
                    Grid.Row="1" Grid.Column="2"
                    Margin="3,0,0,0"
                    Style="{StaticResource PrimaryButtonStyle}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Command="{Binding InternalSaveCommand, RelativeSource={RelativeSource AncestorType=local:DataTreeView}}">
                <StackPanel Orientation="Horizontal">
                    <Image Source="{DynamicResource Icon.Save}" Width="11" Height="11" Margin="0,0,2,0" VerticalAlignment="Center"/>
                    <TextBlock Text="保存" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</UserControl>
