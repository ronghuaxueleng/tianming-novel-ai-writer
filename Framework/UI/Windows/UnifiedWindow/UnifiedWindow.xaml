<Window x:Class="TM.Framework.UI.Windows.UnifiedWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        UseLayoutRounding="True"
        xmlns:controls="clr-namespace:TM.Framework.Common.Controls"
        xmlns:feedback="clr-namespace:TM.Framework.Common.Controls.Feedback"
        Title="天命 - 工作台"
        Width="1400" Height="1000"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        ShowInTaskbar="False">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="15"
                      CornerRadius="8"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>

            <Style x:Key="WindowControlButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="45"/>
                <Setter Property="Height" Value="45"/>
                <Setter Property="Margin" Value="2.5,0,2.5,0"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="ButtonBorder"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="TabRadioButtonStyle" TargetType="RadioButton">
                <Setter Property="Width" Value="45"/>
                <Setter Property="Height" Value="45"/>
                <Setter Property="Margin" Value="2.5,0,2.5,0"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="ButtonBorder"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                    </Trigger>
                    <Trigger Property="IsChecked" Value="True">
                        <Setter Property="Background" Value="{DynamicResource PrimaryColor}"/>
                        <Setter Property="Foreground" Value="White"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="ModeToggleButtonStyle" TargetType="RadioButton">
                <Setter Property="Margin" Value="0,0,10,0"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="ButtonBorder"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="10,5">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                    </Trigger>
                    <Trigger Property="IsChecked" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource PrimaryColor}"/>
                        <Setter Property="FontWeight" Value="ExtraBold"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>

        <Border Background="{DynamicResource GradientBackground}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid x:Name="MainGrid" Background="Transparent">
                <Grid.Clip>
                    <RectangleGeometry RadiusX="8" RadiusY="8" Rect="0,0,10000,10000"/>
                </Grid.Clip>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="5"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="5"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Grid.ColumnSpan="3" Background="Transparent"
                      MouseLeftButtonDown="OnTitleBarMouseDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{DynamicResource SurfaceGlass}"
                            BorderBrush="{DynamicResource GlassBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="3"
                            Margin="10,5,2,5">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="0" BlurRadius="8" Opacity="0.1" Color="Black" RenderingBias="Performance"/>
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal">

                            <Border x:Name="PersonalModeButton"
                                    Background="{DynamicResource PrimaryColor}"
                                    CornerRadius="6"
                                    Width="65"
                                    Height="32"
                                    Margin="0,0,2,0"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="OnPersonalModeClick">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Image Source="{DynamicResource Icon.User}" Width="16" Height="16" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="PersonalModeText"
                                               Text="个人"
                                               Margin="5,0,0,0"
                                               VerticalAlignment="Center"
                                               Foreground="White"
                                               FontWeight="Medium"/>
                                </StackPanel>
                            </Border>

                            <Border x:Name="WritingModeButton"
                                    Background="Transparent"
                                    CornerRadius="6"
                                    Width="65"
                                    Height="32"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="OnWritingModeClick">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Image Source="{DynamicResource Icon.Book}" Width="16" Height="16" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="WritingModeText"
                                               Text="写作"
                                               Margin="5,0,0,0"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextSecondary}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <ItemsControl Grid.Column="1" ItemsSource="{Binding Tabs}"
                                  HorizontalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <RadioButton GroupName="FunctionTabs"
                                             IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                             Style="{StaticResource TabRadioButtonStyle}"
                                             Checked="OnTabChecked">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Image Source="{Binding Icon}"
                                                         Width="13" Height="13"
                                                         HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="13"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,2,0,0"
                                                   Foreground="{DynamicResource TextPrimary}"/>
                                    </StackPanel>
                                </RadioButton>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">

                        <Button x:Name="CreativeButton"
                                Style="{StaticResource WindowControlButtonStyle}"
                                ToolTip="切换到创作台"
                                Click="OnPopupCreativeClick">
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="{DynamicResource Icon.Target}" Width="13" Height="13" HorizontalAlignment="Center"/>
                                <TextBlock Text="创作台" FontSize="13" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Button>
                        <Border Width="1"
                                Height="20"
                                Background="{DynamicResource GlassBorderBrush}"
                                Margin="5,0"
                                VerticalAlignment="Center"/>
                        <Button x:Name="PinButton" Click="OnPinToggleClick"
                                Style="{StaticResource WindowControlButtonStyle}">
                            <StackPanel x:Name="PinButtonContent" HorizontalAlignment="Center" Opacity="0.4">
                                <Image x:Name="PinButtonIcon" Source="{DynamicResource Icon.MapPin}" Width="13" Height="13" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="PinButtonLabel" Text="置顶" FontSize="13" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="MinimizeButton" Click="OnMinimizeClick"
                                Style="{StaticResource WindowControlButtonStyle}"
                                ToolTip="最小化">
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="{DynamicResource Icon.WindowMinimize}" Width="13" Height="13" HorizontalAlignment="Center"/>
                                <TextBlock Text="最小化" FontSize="13" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="MaximizeButton"
                                Click="OnMaximizeClick"
                                Style="{StaticResource WindowControlButtonStyle}">
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="{DynamicResource Icon.WindowMaximize}" Width="13" Height="13" HorizontalAlignment="Center"/>
                                <TextBlock Text="最大化" FontSize="13" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button Click="OnCloseClick"
                                Style="{StaticResource WindowControlButtonStyle}">
                            <StackPanel HorizontalAlignment="Center">
                                <Rectangle Width="13" Height="13" HorizontalAlignment="Center"
                                           Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="{DynamicResource Icon.WindowClose}" Stretch="Uniform"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                                <TextBlock Text="关闭" FontSize="13" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <Rectangle Grid.Row="1" Grid.ColumnSpan="3" Fill="{DynamicResource GlassBorderBrush}"/>

                <Grid Grid.Row="2" Grid.Column="1" x:Name="ContentGrid" Background="Transparent">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="LeftColumn" Width="200" MinWidth="150"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border x:Name="TreeViewBorder"
                            Grid.Column="0"
                            Background="{DynamicResource SurfaceGlass}"
                            BorderBrush="{DynamicResource GlassBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Margin="5,10,2,5">
                        <controls:DataTreeView x:Name="UnifiedTreeView"
                                               ItemsSource="{Binding TreeNodes}"
                                               ParentClickMode="Toggle"
                                               ParentNodeClickCommand="{Binding NodeClickCommand}"
                                               ChildNodeClickCommand="{Binding NodeClickCommand}"
                                               NodeDoubleClickCommand="{Binding NodeDoubleClickCommand}"
                                               Margin="5"
                                               Background="Transparent"/>
                    </Border>

                    <GridSplitter Grid.Column="1" Width="5"
                                  HorizontalAlignment="Center"
                                  Background="Transparent"
                                  ShowsPreview="False"
                                  Cursor="SizeWE"
                                  DragCompleted="OnGridSplitterDragCompleted">
                        <GridSplitter.Style>
                            <Style TargetType="GridSplitter">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource PrimaryColor}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </GridSplitter.Style>
                    </GridSplitter>

                    <Grid x:Name="ViewHostPanel"
                          Grid.Column="2"
                          Margin="2,5,0,5"/>
                </Grid>

                <feedback:BusyOverlay x:Name="ModalDimOverlay"
                                      Grid.Row="0" Grid.RowSpan="4"
                                      Grid.Column="0" Grid.ColumnSpan="3"
                                      IsBusy="False"
                                      OverlayBackground="{DynamicResource BusyOverlayBackground}"
                                      OverlayCornerRadius="8"
                                      Panel.ZIndex="1000">
                    <feedback:BusyOverlay.OverlayContent>
                        <Grid/>
                    </feedback:BusyOverlay.OverlayContent>
                </feedback:BusyOverlay>

                <feedback:BusyOverlay x:Name="AIGenerateOverlay"
                                      Grid.Row="2" Grid.Column="1"
                                      IsBusy="False"
                                      OverlayBackground="{DynamicResource BusyOverlayBackground}"
                                      OverlayCornerRadius="8"
                                      Panel.ZIndex="999">
                    <feedback:BusyOverlay.OverlayContent>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <feedback:LoadingIndicator Width="56" Height="56"/>

                            <TextBlock Text="正在生成..."
                                       Margin="0,12,0,0"
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontSize="14"
                                       TextAlignment="Center"/>

                            <Button Content="取消生成"
                                    Margin="0,14,0,0"
                                    Padding="18,8"
                                    Click="OnCancelAIGenerationClick"
                                    Style="{DynamicResource DangerButtonStyle}"/>
                        </StackPanel>
                    </feedback:BusyOverlay.OverlayContent>
                </feedback:BusyOverlay>
            </Grid>
        </Border>
    </Grid>
</Window>
