<Window x:Class="TM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        UseLayoutRounding="True"
        xmlns:fw="clr-namespace:TM.Framework.UI.Windows"
        xmlns:feedback="clr-namespace:TM.Framework.Common.Controls.Feedback"
        x:Name="RootWindow"
        Title="天命-智能创作"
        Height="1000"
        Width="1400"
        MinHeight="700"
        MinWidth="1000"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        WindowStartupLocation="Manual">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="15"
                      CornerRadius="8"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <fw:ThreeColumnLayout x:Name="LayoutComponent"/>
        <feedback:BusyOverlay IsBusy="{Binding IsNetworkBlocked, ElementName=RootWindow}"
                              Panel.ZIndex="999">
            <feedback:BusyOverlay.OverlayContent>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Image Source="{DynamicResource Icon.Globe}" Width="36" Height="36" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="网络已断开" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding NetworkOverlayMessage, ElementName=RootWindow}"
                               FontSize="13" Opacity="0.85" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
            </feedback:BusyOverlay.OverlayContent>
        </feedback:BusyOverlay>
    </Grid>
</Window>
