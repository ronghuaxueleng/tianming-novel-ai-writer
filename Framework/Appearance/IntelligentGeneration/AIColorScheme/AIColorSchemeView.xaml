<UserControl x:Class="TM.Framework.Appearance.IntelligentGeneration.AIColorScheme.AIColorSchemeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:TM.Framework.Common.Helpers.UI"
             xmlns:local="clr-namespace:TM.Framework.Appearance.IntelligentGeneration.AIColorScheme"
             xmlns:common="clr-namespace:TM.Framework.Common.Controls.Layout"
             xmlns:converters="clr-namespace:TM.Framework.Common.Converters">

    <UserControl.Resources>
        <converters:IconKeyToImageSourceConverter x:Key="IconKeyToImageSourceConverter"/>
    </UserControl.Resources>

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <common:IconHeaderGroupBox Grid.Row="0" Icon="{DynamicResource Icon.Palette}" Title="AI配色生成器" Margin="0,0,0,20" IconSize="16" TitleFontSize="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Image Source="{DynamicResource Icon.Chat}" Width="14" Height="14" Margin="0,0,8,0"/>
                        <TextBlock Text="关键词或描述" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="（可选）" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="5,0,0,0"/>
                    </StackPanel>
                    <Grid Height="36" Margin="0,0,0,15">
                        <TextBox x:Name="KeywordsTextBox"
                                 Text="{Binding Keywords, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="12,0"
                                 VerticalContentAlignment="Center"
                                 FontSize="14"/>
                        <TextBlock Text="例如：海洋、温暖、科技..."
                                   Foreground="{DynamicResource TextTertiary}"
                                   FontSize="14"
                                   Margin="14,0,0,0"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=KeywordsTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap">
                        <Run Text=" 提示：输入关键词（如 海洋、温暖）或留空随机生成基础色"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2">

                    <StackPanel Margin="0,0,0,15">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Image Source="{DynamicResource Icon.Target}" Width="14" Height="14" Margin="0,0,8,0"/>
                            <TextBlock Text="色彩和谐规则" FontSize="14" FontWeight="SemiBold"/>
                        </StackPanel>
                        <ComboBox ItemsSource="{Binding ColorHarmonies}"
                                 SelectedValue="{Binding SelectedColorHarmony, Mode=TwoWay}"
                                 SelectedValuePath="."
                                 Height="36"/>
                    </StackPanel>

                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Image Source="{DynamicResource Icon.Moon}" Width="14" Height="14" Margin="0,0,8,0"/>
                            <TextBlock Text="主题类型" FontSize="14" FontWeight="SemiBold"/>
                        </StackPanel>
                        <ComboBox ItemsSource="{Binding ThemeTypes}"
                                 SelectedValue="{Binding SelectedThemeType, Mode=TwoWay}"
                                 SelectedValuePath="."
                                 Height="36"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,15,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Image Source="{DynamicResource Icon.Heart}" Width="14" Height="14" Margin="0,0,8,0"/>
                        <TextBlock Text="情感色彩" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="（可选）" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="5,0,0,0"/>
                    </StackPanel>
                    <ComboBox ItemsSource="{Binding Emotions}"
                             SelectedValue="{Binding SelectedEmotion, Mode=TwoWay}"
                             SelectedValuePath="."
                             Height="36"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,15,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Image Source="{DynamicResource Icon.Monitor}" Width="14" Height="14" Margin="0,0,8,0"/>
                        <TextBlock Text="使用场景" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="（可选）" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="5,0,0,0"/>
                    </StackPanel>
                    <ComboBox ItemsSource="{Binding Scenes}"
                             SelectedValue="{Binding SelectedScene, Mode=TwoWay}"
                             SelectedValuePath="."
                             Height="36"/>
                </StackPanel>
            </Grid>
        </common:IconHeaderGroupBox>

        <common:IconHeaderGroupBox Grid.Row="1" Icon="{DynamicResource Icon.Palette}" Title="生成的配色方案" ShowCount="True" Count="{Binding GeneratedSchemes.Count}" IconSize="16" TitleFontSize="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding GeneratedSchemes}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="280" Margin="0,0,12,12" CornerRadius="8"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource GlassBorderBrush}"
                                    Background="{DynamicResource ContentBackgroundGlass}">
                                <Grid Margin="14,12">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding SchemeName}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Image Source="{Binding ScoreIcon, Converter={StaticResource IconKeyToImageSourceConverter}}" Width="12" Height="12" Margin="0,0,3,0"/>
                                            <TextBlock Text="{Binding ScoreRating}" FontSize="12"
                                                       Foreground="{DynamicResource TextSecondary}"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Grid.Row="1" Height="36" Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="{Binding PrimaryBrush}" CornerRadius="4,0,0,4"
                                                ToolTip="{Binding PrimaryHex}"/>
                                        <Border Grid.Column="1" Background="{Binding SecondaryBrush}"
                                                ToolTip="{Binding SecondaryHex}"/>
                                        <Border Grid.Column="2" Background="{Binding AccentBrush}"
                                                ToolTip="{Binding AccentHex}"/>
                                        <Border Grid.Column="3" Background="{Binding BackgroundBrush}"
                                                ToolTip="{Binding BackgroundHex}"/>
                                        <Border Grid.Column="4" Background="{Binding TextBrush}" CornerRadius="0,4,4,0"
                                                ToolTip="{Binding TextHex}"/>
                                    </Grid>

                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
                                        <TextBlock Text="{Binding PrimaryHex}" FontSize="11" Margin="0,0,6,0"
                                                   Foreground="{DynamicResource TextSecondary}"/>
                                        <TextBlock Text="{Binding SecondaryHex}" FontSize="11" Margin="0,0,6,0"
                                                   Foreground="{DynamicResource TextSecondary}"/>
                                        <TextBlock Text="{Binding AccentHex}" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondary}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="3" Orientation="Horizontal">
                                        <Button Command="{Binding ApplyCommand}"
                                                Style="{DynamicResource PrimaryButtonStyle}"
                                                Padding="12,6" Margin="0,0,8,0">
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="{DynamicResource Icon.CheckCircle}" Width="12" Height="12" Margin="0,0,5,0"/>
                                                <TextBlock Text="应用"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding SaveCommand}"
                                                Style="{DynamicResource SecondaryButtonStyle}"
                                                Padding="12,6">
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="{DynamicResource Icon.Save}" Width="12" Height="12" Margin="0,0,5,0"/>
                                                <TextBlock Text="加入主题库"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </common:IconHeaderGroupBox>

        <StackPanel Grid.Row="2"
                   Orientation="Horizontal"
                   HorizontalAlignment="Right"
                   Margin="0,20,0,0">

            <Button Command="{Binding ClearSchemesCommand}"
                   Style="{DynamicResource SecondaryButtonStyle}"
                   helpers:ButtonHelper.ConfirmMessage="确定要清除所有生成的配色方案吗？&#x0a;清除后将无法恢复。"
                   helpers:ButtonHelper.ConfirmTitle="确认清除"
                   Padding="20,10"
                   MinWidth="{DynamicResource LargeButtonWidth}"
                   Margin="0,0,10,0">
                <StackPanel Orientation="Horizontal">
                    <Image Source="{DynamicResource Icon.Trash}" Width="14" Height="14" Margin="0,0,8,0"/>
                    <TextBlock Text="清除记录"/>
                </StackPanel>
            </Button>

            <Button Command="{Binding GenerateSchemesCommand}"
                   IsEnabled="{Binding IsGenerating, Converter={StaticResource InverseBoolConverter}}"
                   Style="{DynamicResource PrimaryButtonStyle}"
                   Padding="20,10"
                   MinWidth="{DynamicResource LargeButtonWidth}">
                <StackPanel Orientation="Horizontal">
                    <Image Source="{DynamicResource Icon.Sparkle}" Width="14" Height="14" Margin="0,0,8,0"/>
                    <TextBlock Text="生成配色" FontWeight="Bold"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
