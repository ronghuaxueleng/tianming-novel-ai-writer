<UserControl x:Class="TM.Framework.UI.Windows.ThreeColumnLayout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:workspace="clr-namespace:TM.Framework.UI.Workspace">

    <Border Background="{DynamicResource GradientBackground}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="{StaticResource StandardBorder}"
            CornerRadius="{StaticResource LargeRadius}">
        <Grid x:Name="MainGrid">
            <Grid.Clip>
                <RectangleGeometry RadiusX="8" RadiusY="8" Rect="0,0,10000,10000"/>
            </Grid.Clip>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="15,0,0,0">
                <Border x:Name="AppIconBorder"
                        Width="24" Height="24"
                        CornerRadius="5"
                        ClipToBounds="True"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0"/>
                <TextBlock Text="天命"
                           Style="{StaticResource TitleTextStyle}"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal">

                <Button x:Name="WorkbenchButton"
                        Style="{StaticResource WindowButtonStyle}"
                        ToolTip="切换到工作台"
                        Click="OnOpenWorkbench">
                    <StackPanel HorizontalAlignment="Center">
                        <Image Source="{DynamicResource Icon.Target}" Width="13" Height="13" HorizontalAlignment="Center"/>
                        <TextBlock Text="工作台" FontSize="13" HorizontalAlignment="Center" Margin="0"/>
                    </StackPanel>
                </Button>

                <Border Width="1"
                        Height="20"
                        Background="{DynamicResource GlassBorderBrush}"
                        Margin="5,0"
                        VerticalAlignment="Center"/>

                <Button x:Name="MainPinButton"
                        Style="{StaticResource WindowButtonStyle}"
                        ToolTip="置顶"
                        Click="OnMainPinToggleClick">
                    <StackPanel x:Name="MainPinButtonContent" HorizontalAlignment="Center" Opacity="0.4">
                        <Image Source="{DynamicResource Icon.MapPin}" Width="13" Height="13" HorizontalAlignment="Center"/>
                        <TextBlock Text="置顶" FontSize="13" HorizontalAlignment="Center" Margin="0"/>
                    </StackPanel>
                </Button>

                <Button x:Name="MinimizeButton"
                        Style="{StaticResource WindowButtonStyle}"
                        ToolTip="最小化">
                    <StackPanel HorizontalAlignment="Center">
                        <Image Source="{DynamicResource Icon.WindowMinimize}" Width="13" Height="13" HorizontalAlignment="Center"/>
                        <TextBlock Text="最小化" FontSize="13" HorizontalAlignment="Center" Margin="0"/>
                    </StackPanel>
                </Button>
                <Button x:Name="MaximizeButton"
                        Style="{StaticResource WindowButtonStyle}"
                        ToolTip="最大化">
                    <StackPanel HorizontalAlignment="Center">
                        <Image Source="{DynamicResource Icon.WindowMaximize}" Width="13" Height="13" HorizontalAlignment="Center"/>
                        <TextBlock Text="最大化" FontSize="13" HorizontalAlignment="Center" Margin="0"/>
                    </StackPanel>
                </Button>
                <Button x:Name="CloseButton"
                        Style="{StaticResource CloseButtonStyle}"
                        ToolTip="关闭">
                    <StackPanel HorizontalAlignment="Center">
                        <Rectangle Width="13" Height="13" HorizontalAlignment="Center"
                                   Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                            <Rectangle.OpacityMask>
                                <ImageBrush ImageSource="{DynamicResource Icon.WindowClose}" Stretch="Uniform"/>
                            </Rectangle.OpacityMask>
                        </Rectangle>
                        <TextBlock Text="关闭" FontSize="13" HorizontalAlignment="Center" Margin="0"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <ProgressBar Grid.Row="1" Name="GlobalProgressBar"
                     Height="3" Minimum="0" Maximum="100" Value="0"
                     Visibility="Collapsed"
                     Foreground="{DynamicResource PrimaryColor}"
                     Background="Transparent"
                     BorderThickness="0"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" VerticalAlignment="Top">

            </StackPanel>

            </Grid>

            <Border Grid.Column="1"
                    Background="Transparent"
                    Margin="1,0"
                    CornerRadius="{StaticResource SmallRadius}"
                    ClipToBounds="True">
                <workspace:WorkspaceLayout x:Name="WorkspaceContainer" />
            </Border>

            <Grid Grid.Column="2"/>
        </Grid>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       x:Name="StatusText"
                       Text="就绪"
                       Style="{StaticResource StatusTextStyle}"
                       Margin="15,0,0,0"/>

            <TextBlock Grid.Column="1"
                       Text="作者：子夜-229164036，公益项目未收费"
                       Style="{StaticResource StatusTextStyle}"
                       Margin="0,0,15,0"/>
        </Grid>
        </Grid>
    </Border>
</UserControl>

