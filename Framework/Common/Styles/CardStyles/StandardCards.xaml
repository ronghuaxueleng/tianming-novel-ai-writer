<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SurfaceGlass}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="Margin" Value="0,0,0,15"/>
    </Style>

    <Style x:Key="CompactCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Padding" Value="15"/>
    </Style>

    <Style x:Key="SpacedCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Padding" Value="30"/>
    </Style>

    <Style x:Key="ElevatedCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="Black"
                                Opacity="0.08"
                                BlurRadius="12"
                                ShadowDepth="3"
                                Direction="270"
                                RenderingBias="Performance"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="InteractiveCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryColor}"/>
                <Setter Property="BorderThickness" Value="2"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SelectableCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>

            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
            </Trigger>
        </Style.Triggers>

    </Style>

    <Style x:Key="InfoCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Background" Value="#E7F3FF"/>
        <Setter Property="BorderBrush" Value="#90CAF9"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <Style x:Key="SuccessCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Background" Value="#E8F5E9"/>
        <Setter Property="BorderBrush" Value="#81C784"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <Style x:Key="WarningCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Background" Value="#FFF3CD"/>
        <Setter Property="BorderBrush" Value="#FFE69C"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <Style x:Key="DangerCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Background" Value="#FFEBEE"/>
        <Setter Property="BorderBrush" Value="#EF9A9A"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <Style x:Key="CardTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>

    <Style x:Key="CardSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <Style x:Key="CardDescriptionStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="LineHeight" Value="18"/>
    </Style>

    <Style x:Key="StandardGroupBoxStyle" TargetType="GroupBox">
        <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GroupBox">
                    <Grid SnapsToDevicePixels="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.ColumnSpan="3" Grid.RowSpan="2"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Margin="0,10,0,0"/>

                        <Border Grid.Column="0" Grid.RowSpan="2"
                                Background="Transparent"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1,1,0,1"
                                CornerRadius="6,0,0,6"
                                Margin="0,10,0,0"/>
                        <Border Grid.Column="2" Grid.RowSpan="2"
                                Background="Transparent"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,1,1,1"
                                CornerRadius="0,6,6,0"
                                Margin="0,10,0,0"/>
                        <Border Grid.Column="1" Grid.Row="1"
                                Background="Transparent"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Margin="-1,0,-1,0"/>

                        <Border Grid.Column="0" Grid.Row="0"
                                Background="Transparent"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0"
                                Margin="0"/>

                        <Border Grid.Column="2" Grid.Row="0"
                                Background="Transparent"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0"
                                Margin="0"/>

                        <ContentPresenter Grid.Column="1" Grid.Row="0"
                                          ContentSource="Header"
                                          RecognizesAccessKey="True"
                                          VerticalAlignment="Center"
                                          Margin="4,2"/>

                        <ContentPresenter Grid.ColumnSpan="3" Grid.Row="1"
                                          Margin="{TemplateBinding Padding}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CardHeaderStyle" TargetType="Border">
        <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="0,0,0,12"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
    </Style>

    <Style x:Key="ThemeCardStyle" TargetType="Border">
        <Setter Property="Width" Value="165"/>
        <Setter Property="Height" Value="145"/>
        <Setter Property="Margin" Value="6"/>
        <Setter Property="Background" Value="{DynamicResource SurfaceGlass}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="Black"
                                        Opacity="0.1"
                                        BlurRadius="10"
                                        ShadowDepth="2"
                                        Direction="270"
                                        RenderingBias="Performance"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SelectedThemeCardStyle" TargetType="Border" BasedOn="{StaticResource ThemeCardStyle}">
        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryColor}"/>
        <Setter Property="BorderThickness" Value="3"/>
    </Style>

    <Style x:Key="CurrentThemeCardStyle" TargetType="Border" BasedOn="{StaticResource ThemeCardStyle}">
        <Setter Property="BorderBrush" Value="#28a745"/>
        <Setter Property="BorderThickness" Value="3"/>
    </Style>

</ResourceDictionary>

