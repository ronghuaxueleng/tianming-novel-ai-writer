<UserControl x:Class="TM.Modules.Design.SmartParsing.BookAnalysis.BookAnalysisView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dm="clr-namespace:TM.Framework.Common.Controls.DataManagement"
             xmlns:layout="clr-namespace:TM.Framework.Common.Controls.Layout"
             xmlns:feedback="clr-namespace:TM.Framework.Common.Controls.Feedback"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf">

    <Grid>
    <dm:TwoColumnEditorLayout
        LeftIcon="{DynamicResource Icon.Book}"
        LeftTitle="智能拆书"
        RightIcon="{DynamicResource Icon.Book}"
        RightTitle="书籍分析"
        ItemsSource="{Binding TreeData}"
        ShowSearch="True"
        SearchKeyword="{Binding SearchKeyword, Mode=TwoWay}"
        NodeDoubleClickCommand="{Binding SelectNodeCommand}"
        AddCommand="{Binding AddCommand}"
        SaveCommand="{Binding SaveCommand}"
        DeleteCommand="{Binding DeleteCommand}"
        DeleteAllCommand="{Binding DeleteAllCommand}"
        TreeAfterActionCommand="{Binding TreeAfterActionCommand}"
        AIGenerateCommand="{Binding AIGenerateCommand}"
        IsAIGenerateEnabled="{Binding IsAIGenerateEnabled}"
        UseStandardScheme2Layout="True"
        Tab1Header="在线获取"
        Tab2Header="源书爬取"
        Tab3Header="世界观分析"
        Tab4Header="角色分析"
        Tab5Header="剧情分析">

        <dm:TwoColumnEditorLayout.EditAdditionalContent>
            <Grid MinHeight="570">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Grid.RowSpan="2" Grid.IsSharedSizeScope="True">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="G_Label"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="G_Btn1"/>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="G_Btn2"/>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="G_Btn3"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="网站地址：" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondary}" Margin="0,0,8,0"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding CurrentUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource StandardTextBoxStyle}"
                                 Height="36" Margin="0,0,8,0"
                                 KeyDown="UrlTextBox_KeyDown"
                                 VerticalContentAlignment="Center"/>
                        <Button Grid.Column="2" Content="搜索"
                                Command="{Binding NavigateCommand}"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Margin="0,0,8,0" Padding="12,8"/>
                        <Button Grid.Column="3"
                                Command="{Binding GoBackCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Margin="0,0,8,0" Padding="12,8">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Image Source="{DynamicResource Icon.ChevronLeft}" Width="14" Height="14" Margin="0,0,8,0"/>
                                <TextBlock Text="返回" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="4" Content=" 本地导入"
                                Command="{Binding ImportLocalFileCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="12,8"/>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="G_Label"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="G_Btn1"/>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="G_Btn2"/>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="G_Btn3"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="历史记录：" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondary}" Margin="0,0,8,0"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding UrlHistory}"
                                  SelectedItem="{Binding SelectedHistoryUrl, Mode=TwoWay}"
                                  Style="{DynamicResource StandardComboBoxStyle}"
                                  Height="36" Margin="0,0,8,0"/>
                        <Button Grid.Column="2" Content="提取书名"
                                Command="{Binding ExtractBookInfoCommand}"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Margin="0,0,8,0" Padding="12,8"/>
                        <Button Grid.Column="3" Content="获取精华章"
                                Command="{Binding GetEssenceChaptersCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Margin="0,0,8,0" Padding="12,8"/>
                        <Button Grid.Column="4" Content="清除历史"
                                Command="{Binding ClearUrlHistoryCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="12,8"/>
                    </Grid>
                </Grid>

                <Border Grid.Row="2" BorderBrush="{DynamicResource GlassBorderBrush}"
                        BorderThickness="1" CornerRadius="6" Background="{DynamicResource ContentBackgroundGlass}">
                    <Grid>

                        <wv2:WebView2 Loaded="WebView_Loaded"
                                      Visibility="{Binding IsWebViewVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <TextBlock Text="输入网址后点击「搜索」打开页面"
                                   Foreground="{DynamicResource TextTertiary}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="14"
                                   Visibility="{Binding IsWebViewVisible, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                    </Grid>
                </Border>
            </Grid>
        </dm:TwoColumnEditorLayout.EditAdditionalContent>

        <dm:TwoColumnEditorLayout.DetailsContent>
            <Grid>
<Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                    <layout:IconHeaderGroupBox Grid.Row="0" Icon="{DynamicResource Icon.Books}" Title="源书信息" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Column="0" Grid.Row="0" Text="源书书名" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBox Grid.Column="0" Grid.Row="1" Text="{Binding SourceBookTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource StandardTextBoxStyle}" Height="36"/>

                            <TextBlock Grid.Column="2" Grid.Row="0" Text="源书作者" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBox Grid.Column="2" Grid.Row="1" Text="{Binding SourceAuthor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource StandardTextBoxStyle}" Height="36"/>

                            <TextBlock Grid.Column="4" Grid.Row="0" Text="类型/题材" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBox Grid.Column="4" Grid.Row="1" Text="{Binding SourceGenre, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource StandardTextBoxStyle}" Height="36"/>

                            <TextBlock Grid.Column="6" Grid.Row="0" Text="关键词/标签" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBox Grid.Column="6" Grid.Row="1" Text="{Binding SourceKeywords, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource StandardTextBoxStyle}" Height="36"/>
                        </Grid>
                    </layout:IconHeaderGroupBox>

                    <layout:IconHeaderGroupBox Grid.Row="1" Icon="{DynamicResource Icon.Chart}" Title="爬取统计" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="章节数：" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding ChapterCount}" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" Margin="5,0,20,0"/>
                            <TextBlock Grid.Column="2" Text="总字数：" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="{Binding TotalWordCount}" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" Margin="5,0,20,0"/>
                            <TextBlock Grid.Column="4" Text="爬取时间：" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="5" Text="{Binding CrawledAtDisplay}" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" Margin="5,0,0,0"/>
                        </Grid>
                    </layout:IconHeaderGroupBox>

                    <layout:IconHeaderGroupBox Grid.Row="2" Icon="{DynamicResource Icon.Document}" Title="章节预览" Margin="0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <ListBox Grid.Column="0"
                                     ItemsSource="{Binding ChapterList}"
                                     SelectedItem="{Binding SelectedChapter}"
                                     DisplayMemberPath="Title"
                                     BorderBrush="{DynamicResource GlassBorderBrush}"
                                     BorderThickness="1"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.VirtualizationMode="Recycling"
                                     ScrollViewer.CanContentScroll="True"/>

                            <Border Grid.Column="2" BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1" CornerRadius="6">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                                    <TextBlock Text="{Binding SelectedChapterContent}"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextPrimary}"/>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </layout:IconHeaderGroupBox>
            </Grid>
        </dm:TwoColumnEditorLayout.DetailsContent>

        <dm:TwoColumnEditorLayout.Tab3Content>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <layout:IconHeaderGroupBox Grid.Row="0" Icon="{DynamicResource Icon.Globe}" Title="世界构建手法" Margin="0,0,0,5">
                    <TextBox Text="{Binding FormWorldBuildingMethod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             Height="Auto" VerticalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                </layout:IconHeaderGroupBox>
                <layout:IconHeaderGroupBox Grid.Row="1" Icon="{DynamicResource Icon.Lightning}" Title="力量体系设计" Margin="0,0,0,5">
                    <TextBox Text="{Binding FormPowerSystemDesign, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             Height="Auto" VerticalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                </layout:IconHeaderGroupBox>
                <layout:IconHeaderGroupBox Grid.Row="2" Icon="{DynamicResource Icon.Landscape}" Title="环境描写技巧" Margin="0,0,0,5">
                    <TextBox Text="{Binding FormEnvironmentDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             Height="Auto" VerticalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                </layout:IconHeaderGroupBox>
                <layout:IconHeaderGroupBox Grid.Row="3" Icon="{DynamicResource Icon.Castle}" Title="势力设计技巧" Margin="0,0,0,5">
                    <TextBox Text="{Binding FormFactionDesign, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             Height="Auto" VerticalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                </layout:IconHeaderGroupBox>
                <layout:IconHeaderGroupBox Grid.Row="4" Icon="{DynamicResource Icon.Sparkle}" Title="世界观亮点" Margin="0">
                    <TextBox Text="{Binding FormWorldviewHighlights, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             Height="Auto" VerticalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                </layout:IconHeaderGroupBox>
            </Grid>
        </dm:TwoColumnEditorLayout.Tab3Content>

        <dm:TwoColumnEditorLayout.Tab4Content>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <layout:IconHeaderGroupBox Grid.Row="0" Icon="{DynamicResource Icon.User}" Title="主角塑造手法" Margin="0,0,0,5">
                    <TextBox Text="{Binding FormProtagonistDesign, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             Height="Auto" VerticalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                </layout:IconHeaderGroupBox>
                <layout:IconHeaderGroupBox Grid.Row="1" Icon="{DynamicResource Icon.Users}" Title="配角设计技巧" Margin="0,0,0,5">
                    <TextBox Text="{Binding FormSupportingRoles, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             Height="Auto" VerticalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                </layout:IconHeaderGroupBox>
                <layout:IconHeaderGroupBox Grid.Row="2" Icon="{DynamicResource Icon.Link}" Title="人物关系设计" Margin="0,0,0,5">
                    <TextBox Text="{Binding FormCharacterRelations, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             Height="Auto" VerticalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                </layout:IconHeaderGroupBox>
                <layout:IconHeaderGroupBox Grid.Row="3" Icon="{DynamicResource Icon.Hand}" Title="金手指设计" Margin="0,0,0,5">
                    <TextBox Text="{Binding FormGoldenFingerDesign, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             Height="Auto" VerticalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                </layout:IconHeaderGroupBox>
                <layout:IconHeaderGroupBox Grid.Row="4" Icon="{DynamicResource Icon.Sparkle}" Title="角色塑造亮点" Margin="0">
                    <TextBox Text="{Binding FormCharacterHighlights, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             Height="Auto" VerticalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                </layout:IconHeaderGroupBox>
            </Grid>
        </dm:TwoColumnEditorLayout.Tab4Content>

        <dm:TwoColumnEditorLayout.Tab5Content>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <layout:IconHeaderGroupBox Grid.Row="0" Icon="{DynamicResource Icon.Book}" Title="情节结构技巧" Margin="0,0,0,5">
                    <TextBox Text="{Binding FormPlotStructure, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             Height="Auto" VerticalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                </layout:IconHeaderGroupBox>
                <layout:IconHeaderGroupBox Grid.Row="1" Icon="{DynamicResource Icon.Swords}" Title="冲突设计手法" Margin="0,0,0,5">
                    <TextBox Text="{Binding FormConflictDesign, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             Height="Auto" VerticalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                </layout:IconHeaderGroupBox>
                <layout:IconHeaderGroupBox Grid.Row="2" Icon="{DynamicResource Icon.Fire}" Title="高潮布局技巧" Margin="0,0,0,5">
                    <TextBox Text="{Binding FormClimaxArrangement, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             Height="Auto" VerticalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                </layout:IconHeaderGroupBox>
                <layout:IconHeaderGroupBox Grid.Row="3" Icon="{DynamicResource Icon.Theater}" Title="伏笔技巧" Margin="0,0,0,5">
                    <TextBox Text="{Binding FormForeshadowingTechnique, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             Height="Auto" VerticalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                </layout:IconHeaderGroupBox>
                <layout:IconHeaderGroupBox Grid.Row="4" Icon="{DynamicResource Icon.Sparkle}" Title="剧情设计亮点" Margin="0">
                    <TextBox Text="{Binding FormPlotHighlights, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             Height="Auto" VerticalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                </layout:IconHeaderGroupBox>
            </Grid>
        </dm:TwoColumnEditorLayout.Tab5Content>

    </dm:TwoColumnEditorLayout>

    </Grid>
</UserControl>
