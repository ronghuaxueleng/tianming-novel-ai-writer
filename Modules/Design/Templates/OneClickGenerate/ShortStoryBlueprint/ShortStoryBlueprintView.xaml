<UserControl x:Class="TM.Modules.Design.Templates.OneClickGenerate.ShortStoryBlueprint.ShortStoryBlueprintView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dm="clr-namespace:TM.Framework.Common.Controls.DataManagement"
             xmlns:layout="clr-namespace:TM.Framework.Common.Controls.Layout">

    <dm:TwoColumnEditorLayout
        LeftIcon="{DynamicResource Icon.Book}"
        LeftTitle="蓝图目录"
        RightIcon="{DynamicResource Icon.Book}"
        RightTitle="蓝图详情"
        ItemsSource="{Binding TreeData}"
        ShowSearch="True"
        SearchKeyword="{Binding SearchKeyword, Mode=TwoWay}"
        NodeDoubleClickCommand="{Binding SelectNodeCommand}"
        AddCommand="{Binding AddCommand}"
        SaveCommand="{Binding SaveCommand}"
        DeleteCommand="{Binding DeleteCommand}"
        DeleteAllCommand="{Binding DeleteAllCommand}"
        TreeAfterActionCommand="{Binding TreeAfterActionCommand}"
        AIGenerateCommand="{Binding AIGenerateCommand}"
        IsAIGenerateEnabled="{Binding IsAIGenerateEnabled}"
        UseStandardScheme2Layout="True"
        Tab1Header="概览"
        Tab2Header="章节蓝图">

        <dm:TwoColumnEditorLayout.EditAdditionalContent>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <layout:IconHeaderGroupBox Grid.Row="0" Icon="{DynamicResource Icon.Books}" Title="来源拆书" RequiredMark="True" Margin="0,0,0,8">
                    <ComboBox ItemsSource="{Binding BookOptions}"
                              SelectedValue="{Binding FormBookAnalysisId, Mode=TwoWay}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="DisplayName"
                              Style="{DynamicResource StandardComboBoxStyle}" Height="36"/>
                </layout:IconHeaderGroupBox>

                <Grid Grid.Row="1" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="总章节数（必填）" Margin="0,0,0,5"
                                   Foreground="{DynamicResource DangerColor}"/>
                        <Grid>
                            <TextBox Text="{Binding FormTotalChapters, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                     Style="{DynamicResource StandardTextBoxStyle}" Height="36"
                                     IsReadOnly="{Binding IsTotalChaptersLocked}"
                                     ToolTip="必须为数字，填写后章节蓝图自动生成对应行数"/>
                            <TextBlock Text="必须手动填写总章节数" IsHitTestVisible="False"
                                       Margin="12,0,0,0" VerticalAlignment="Center"
                                       Foreground="{DynamicResource DangerColor}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FormTotalChapters}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="题材/类型（必选）" Margin="0,0,0,5"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <ComboBox ItemsSource="{Binding GenreOptions}"
                                  SelectedValue="{Binding FormGenre, Mode=TwoWay}"
                                  SelectedValuePath="Name"
                                  Style="{DynamicResource StandardComboBoxStyle}" Height="36">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel>
                                        <Image Source="{Binding Icon}" Width="14" Height="14"
                                                         DockPanel.Dock="Left" Margin="0,0,6,0"
                                                         VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                   DockPanel.Dock="Left" VerticalAlignment="Center"/>
                                    </DockPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <layout:IconHeaderGroupBox Grid.Row="2" Icon="{DynamicResource Icon.Moon}" Title="基调/氛围" Margin="0,0,0,8">
                    <TextBox Text="{Binding FormToneGuide, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             MinHeight="60" MaxHeight="80" BorderThickness="0" Background="Transparent"/>
                </layout:IconHeaderGroupBox>

                <layout:IconHeaderGroupBox Grid.Row="3" Icon="{DynamicResource Icon.Edit}" Title="全篇简介" Margin="0">
                    <TextBox Text="{Binding FormSynopsis, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             Height="Auto" VerticalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                </layout:IconHeaderGroupBox>
            </Grid>
        </dm:TwoColumnEditorLayout.EditAdditionalContent>

        <dm:TwoColumnEditorLayout.DetailsContent>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource ContentHighlight}"
                        CornerRadius="6" Padding="8,6" Margin="0,0,0,10">
                    <DockPanel LastChildFill="True">

                        <Button DockPanel.Dock="Left"
                                Command="{Binding PrevChapterCommand}"
                                Width="32" Height="32"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Margin="0,0,4,0">
                            <Image Source="{DynamicResource Icon.ChevronLeft}" Width="14" Height="14"/>
                        </Button>

                        <Button DockPanel.Dock="Left"
                                Command="{Binding NextChapterCommand}"
                                Width="32" Height="32"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Margin="0,0,8,0">
                            <Image Source="{DynamicResource Icon.ChevronRight}" Width="14" Height="14"/>
                        </Button>

                        <ComboBox DockPanel.Dock="Right"
                                  ItemsSource="{Binding ChapterBlueprints}"
                                  SelectedIndex="{Binding CurrentChapterIndex, Mode=TwoWay}"
                                  DisplayMemberPath="Title"
                                  Style="{DynamicResource StandardComboBoxStyle}"
                                  Width="130" Height="32" Margin="8,0,0,0"/>

                        <TextBlock DockPanel.Dock="Right"
                                   Text="{Binding CurrentChapterLabel, Mode=OneWay}"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="12" Margin="8,0,0,0"/>

                        <TextBox Text="{Binding CurrentChapterBlueprint.Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource StandardTextBoxStyle}"
                                 Height="32" VerticalAlignment="Center"
                                 ToolTip="章节标题"/>
                    </DockPanel>
                </Border>

                <layout:IconHeaderGroupBox Grid.Row="1" Icon="{DynamicResource Icon.Lightning}" Title="主要事件" Margin="0,0,0,5">
                    <TextBox Text="{Binding CurrentChapterBlueprint.KeyEvents, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             Height="Auto" VerticalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                </layout:IconHeaderGroupBox>

                <layout:IconHeaderGroupBox Grid.Row="2" Icon="{DynamicResource Icon.Users}" Title="出场人物" Margin="0,0,0,5">
                    <TextBox Text="{Binding CurrentChapterBlueprint.Characters, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             Height="Auto" VerticalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                </layout:IconHeaderGroupBox>

                <layout:IconHeaderGroupBox Grid.Row="3" Icon="{DynamicResource Icon.End}" Title="结尾方向" Margin="0">
                    <TextBox Text="{Binding CurrentChapterBlueprint.EndingNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             Height="Auto" VerticalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                </layout:IconHeaderGroupBox>
            </Grid>
        </dm:TwoColumnEditorLayout.DetailsContent>

    </dm:TwoColumnEditorLayout>
</UserControl>
