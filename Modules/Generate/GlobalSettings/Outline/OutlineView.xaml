<UserControl
    x:Class="TM.Modules.Generate.GlobalSettings.Outline.OutlineView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dm="clr-namespace:TM.Framework.Common.Controls.DataManagement"
    xmlns:layout="clr-namespace:TM.Framework.Common.Controls.Layout">
<dm:TwoColumnEditorLayout
    LeftIcon="{DynamicResource Icon.Book}"
    LeftTitle="大纲列表"
    RightIcon="{DynamicResource Icon.Book}"
    RightTitle="大纲编辑"
    ItemsSource="{Binding TreeData}"
    ShowSearch="True"
    SearchKeyword="{Binding SearchKeyword, Mode=TwoWay}"
    NodeDoubleClickCommand="{Binding SelectNodeCommand}"
    AddCommand="{Binding AddCommand}"
    SaveCommand="{Binding SaveCommand}"
    DeleteCommand="{Binding DeleteCommand}"
    DeleteAllCommand="{Binding DeleteAllCommand}"
    TreeAfterActionCommand="{Binding TreeAfterActionCommand}"
    UseStandardScheme2Layout="True"
    Tab1Header="全书定位"
    Tab2Header="主题内核"
    Tab3Header="结构规划">

    <dm:TwoColumnEditorLayout.EditAdditionalContent>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <layout:IconHeaderGroupBox Grid.Row="0" Icon="{DynamicResource Icon.Chart}" Title="全书规划参数" Margin="0,0,0,10">
                <Grid>

                    <StackPanel>
                        <TextBlock Text="总章节数（必填）" Margin="0,0,0,5" Foreground="{DynamicResource DangerColor}"/>
                        <Grid>
                            <TextBox Text="{Binding FormTotalChapterCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource StandardTextBoxStyle}" Height="36"
                                     ToolTip="必须为数字。分卷设计将按此章节数自动计算每卷的起始/结束章节"/>
                            <TextBlock Text="必须手动填写总章节数" IsHitTestVisible="False"
                                       Margin="12,0,0,0" VerticalAlignment="Center"
                                       Foreground="{DynamicResource DangerColor}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FormTotalChapterCount}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </Grid>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="1" Icon="{DynamicResource Icon.Edit}" Title="一句话大纲" Margin="0,0,0,10">
                <TextBox Text="{Binding FormOneLineOutline, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="2" Icon="{DynamicResource Icon.Theater}" Title="情感基调" Margin="0,0,0,10">
                <TextBox Text="{Binding FormEmotionalTone, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="3" Icon="{DynamicResource Icon.Brain}" Title="哲学母题/核心辩题" Margin="0">
                <TextBox Text="{Binding FormPhilosophicalMotif, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>
        </Grid>
    </dm:TwoColumnEditorLayout.EditAdditionalContent>

    <dm:TwoColumnEditorLayout.DetailsContent>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <layout:IconHeaderGroupBox Grid.Row="0" Icon="{DynamicResource Icon.Lightbulb}" Title="主题思想" Margin="0,0,0,10">
                <TextBox Text="{Binding FormTheme, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="1" Icon="{DynamicResource Icon.Swords}" Title="核心冲突" Margin="0,0,0,10">
                <TextBox Text="{Binding FormCoreConflict, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="2" Icon="{DynamicResource Icon.Target}" Title="结局/目标状态" Margin="0">
                <TextBox Text="{Binding FormEndingState, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>
        </Grid>
    </dm:TwoColumnEditorLayout.DetailsContent>

    <dm:TwoColumnEditorLayout.Tab3Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="3*"/>
            </Grid.RowDefinitions>

            <layout:IconHeaderGroupBox Grid.Row="0" Icon="{DynamicResource Icon.Books}" Title="卷/幕划分" Margin="0,0,0,10">
                <TextBox Text="{Binding FormVolumeDivision, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="1" Icon="{DynamicResource Icon.Clipboard}" Title="大纲总览" Margin="0">
                <TextBox Text="{Binding FormOutlineOverview, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>
        </Grid>
    </dm:TwoColumnEditorLayout.Tab3Content>

</dm:TwoColumnEditorLayout>
</UserControl>
